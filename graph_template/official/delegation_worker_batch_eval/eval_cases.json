{
  "suite": "delegation_worker_batch_eval_core",
  "name": "Delegation Worker Batch 核心回归",
  "description": "覆盖真实 Batch/Subgraph worker 编排、并发预算和父图 merge/review 协议，确保多个 worker_result_package 能合并为标准 worker_merge_review_package。",
  "cases": [
    {
      "case_id": "delegation-worker-batch-merges-subgraph-results",
      "name": "Worker 批次应并发运行并合并结果",
      "description": "输入两个 worker_task_packet、worker outputs 和 worker statuses，运行 Batch/Subgraph worker 后用 worker_merge_review check 验证合并状态、输出键、source refs 和关键内容。",
      "inputs": {
        "worker_task_packets": [
          {
            "task_id": "worker_eval_research_1",
            "goal": "Compare TooGraph and Hermes delegation protocols.",
            "context_package_refs": [
              {"source_kind": "context_package", "source_id": "ctx_eval_worker_batch_brief"}
            ],
            "allowed_capabilities": [
              {"kind": "tool", "key": "knowledge_context_loader"}
            ],
            "budget": {"max_steps": 2, "max_chars": 4000},
            "expected_output_schema": {"findings": {"type": "markdown"}}
          },
          {
            "task_id": "worker_eval_research_2",
            "goal": "Check fallback behavior for delegation workers.",
            "context_package_refs": [
              {"source_kind": "context_package", "source_id": "ctx_eval_worker_batch_brief"}
            ],
            "allowed_capabilities": [
              {"kind": "tool", "key": "provider_fallback_resolver"}
            ],
            "budget": {"max_steps": 2, "max_chars": 4000},
            "expected_output_schema": {"findings": {"type": "markdown"}}
          }
        ],
        "worker_outputs_list": [
          {
            "findings": "TooGraph should expose worker_task_packet, worker_result_package, and worker_merge_review_package so Hermes-style delegation remains auditable.",
            "source_refs": [
              {"source_kind": "context_package", "source_id": "ctx_eval_worker_batch_brief"}
            ]
          },
          {}
        ],
        "worker_statuses": ["succeeded", "failed"],
        "worker_budget_usages": [
          {"used_steps": 2, "attempts": 2},
          {"used_steps": 3, "used_chars": 4500}
        ],
        "merge_goal": "Merge delegation worker findings for Hermes parity review.",
        "expected_output_schema": {"findings": {"type": "markdown", "name": "Findings"}},
        "review_policy": {"require_all_succeeded": true, "require_outputs": ["findings"]}
      },
      "checks": [
        {
          "kind": "graph_run",
          "name": "delegation_worker_batch_runs_parent_template",
          "target": "graph_run",
          "required_status": "completed",
          "required_metadata": {
            "eval": {
              "suite_id": "delegation_worker_batch_eval_core",
              "case_id": "delegation-worker-batch-merges-subgraph-results",
              "target_template_id": "delegation_worker_batch_eval"
            }
          },
          "required_state_keys": [
            "worker_task_packets",
            "worker_result_packages",
            "worker_merge_review_package"
          ],
          "required_node_ids": [
            "run_worker_batch",
            "merge_worker_results",
            "output_worker_merge_review"
          ],
          "min_node_executions": 3
        },
        {
          "kind": "worker_merge_review",
          "name": "delegation_worker_batch_merge_contract",
          "target": "worker_merge_review_package",
          "required_status": "partial",
          "required_output_keys": ["findings"],
          "required_source_refs": [
            {"source_kind": "context_package", "source_id": "ctx_eval_worker_batch_brief"}
          ],
          "required_terms": [
            "worker_eval_research_1",
            "worker_eval_research_2",
            "tighten_budget_or_split_task",
            "worker_budget_exhausted",
            "worker_retried",
            "worker_merge_review_package"
          ],
          "forbidden_terms": ["unscoped secret"]
        }
      ]
    }
  ]
}
