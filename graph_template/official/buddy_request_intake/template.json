    },
    {
      "source": "input_page_context",
      "target": "understand_request"
    },
    {
      "source": "understand_request",
      "target": "need_clarification"
    },
    {
      "source": "understand_request",
      "target": "output_visible_reply"
    },
    {
      "source": "input_buddy_context",
      "target": "understand_request"
    },
    {
      "source": "input_context_brief",
      "target": "understand_request"
    },
    {
      "source": "ask_clarification",
      "target": "output_request_understanding"
    },
    {
      "source": "ask_clarification",
      "target": "output_visible_reply"
    }
  ],
  "conditional_edges": [
    {
      "source": "need_clarification",
      "branches": {
        "true": "ask_clarification",
        "false": "output_request_understanding",
        "exhausted": "output_request_understanding"
      }
    }
  ],
  "metadata": {
    "graphProtocol": "node_system",
    "role": "buddy_request_intake",
    "internal": true
  }
}
