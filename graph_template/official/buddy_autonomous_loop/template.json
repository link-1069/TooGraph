      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "conversation_history": {
      "name": "会话历史",
      "description": "由 buddy_history_context_loader 从运行时上下文查询出的历史会话 context_package；LLM 提示词会通过共享上下文渲染路径展开。",
      "type": "json",
      "value": {},
      "color": "#64748b",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "buddy_history_context_loader",
        "nodeId": "load_history_context",
        "fieldKey": "conversation_history",
        "managed": true
      }
    },
    "buddy_context": {
      "name": "Buddy Home",
      "description": "固定的 Buddy Home 文件夹上下文，会作为普通文件 state 直接传递给后续 Buddy LLM 节点。",
      "type": "file",
      "value": {
        "kind": "local_folder",
        "root": "buddy_home",
        "selected": [
          "AGENTS.md",
          "SOUL.md",
          "USER.md",
          "MEMORY.md"
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "needs_context_compaction": {
      "name": "需要上下文压缩",
      "description": "为 true 时，图应在下一次 Buddy LLM 回合前运行 buddy_context_compaction 压缩会话历史。",
      "type": "boolean",
      "value": false,
      "color": "#0891b2",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "buddy_context_pressure_check",
        "nodeId": "check_context_pressure",
        "fieldKey": "needs_context_compaction",
        "managed": true
      }
    },
    "needs_capability": {
      "name": "需要继续调用能力",
      "description": "为 true 时图会执行 selected_capability 指向的一个能力；为 false 表示不再调用能力，接下来只展示结果包或结束。",
      "type": "boolean",
      "value": false,
      "color": "#0891b2",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_capability_selector",
        "toolKey": "",
        "nodeId": "reply_and_select_capability",
        "fieldKey": "needs_capability",
        "managed": true
      }
    },
    "selected_capability": {
      "name": "下一步能力",
      "description": "本轮若需要继续调用能力，这里保存唯一一个被选中的 action/subgraph/tool；不需要能力时必须为 kind=none。",
      "type": "capability",
      "value": {
        "kind": "none"
      },
      "color": "#2563eb",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_capability_selector",
        "toolKey": "",
        "nodeId": "reply_and_select_capability",
        "fieldKey": "capability",
        "managed": true
      }
    },
    "capability_result": {
      "name": "结果包",
      "description": "上一轮动态能力执行产生的结构化结果包。show_result_package=true 时直接展示；否则作为整理回复或下一轮判断的上下文。",
      "type": "result_package",
      "value": {},
      "color": "#0284c7",
      "binding": {
        "kind": "capability_result",
        "actionKey": "",
        "toolKey": "",
        "nodeId": "execute_capability",
        "fieldKey": "result_package",
        "managed": true
      }
    },
    "show_result_package": {
      "name": "展示结果包",
      "description": "为 true 时紧接着把 capability_result 作为下一条可见消息展示给用户，并结束本轮循环；它不是“模型是否能回答”，而是“是否原样展示结果包”。",
      "type": "boolean",
      "value": false,
      "color": "#059669",
      "binding": null
    },
    "public_response": {
      "name": "模型整理回复",
      "description": "每次“回复并判断是否调用能力”运行都必须写入的用户可见回复：需要能力时写简短计划；不需要能力时写完整最终回复；show_result_package=true 时只说明即将展示的结果包类型，不复述结果包全文。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    }
  },
