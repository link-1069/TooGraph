              "ui": { "position": { "x": 2200, "y": 480 }, "collapsed": false },
              "reads": [{ "state": "operation_journal", "required": false }],
              "writes": [],
              "config": { "displayMode": "json", "persistEnabled": false, "persistFormat": "auto", "fileNameTemplate": "" }
