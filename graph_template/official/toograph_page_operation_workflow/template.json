              "writes": [{ "state": "operation_request", "mode": "replace" }],
              "config": {
                "skillKey": "",
                "skillBindings": [],
                "skillInstructionBlocks": {},
                "taskInstruction": "根据 user_goal、goal_plan、operation_result、goal_review 和 loop_trace 选择下一步页面操作意图并写 operation_request JSON。不要输出 DOM selector、坐标、截图描述或浏览器自动化步骤；具体可用命令由下一节点绑定的页面操作器 Skill 从 runtime context 的页面操作书中选择。若目标是运行指定图模板，operation_request 必须包含 semantic_intent=run_template、target_template_id、target_template_name、search_text、input_text=user_goal、requires_terminal_run=true，并让下一节点只输出 template_target，不输出逐步 commands。字段至少包含 target_hint、semantic_intent、reason、expected_route、expected_entity、expected_run、expected_graph_change、requires_terminal_run、blocked_reason。若目标已完成，blocked_reason 写 already_completed；若缺少必要信息，blocked_reason 写 needs_clarification。不要调用技能。",
                "modelSource": "global",
                "model": "",
                "thinkingMode": "high",
                "temperature": 0.1
              }
            },
            "execute_page_operation": {
              "kind": "agent",
              "name": "执行页面操作",
