{
  "template_id": "toograph_page_operation_workflow",
  "label": "操作 TooGraph 页面",
  "description": "当用户要求打开页面、点击按钮、操作 UI 或编辑当前 TooGraph 图，并且需要可见执行和结果验证时使用。",
  "default_graph_name": "操作 TooGraph 页面",
  "state_schema": {
    "user_goal": {
      "name": "用户目标",
      "description": "用户希望 TooGraph 当前页面完成的具体目标。",
      "type": "text",
      "value": "打开运行记录",
      "color": "#d97706",
      "binding": null
    },
    "page_operation_context": {
      "name": "页面操作上下文",
      "description": "结构化页面操作书、页面快照和页面事实，由前端在运行或恢复时注入。",
      "type": "json",
      "value": {},
      "color": "#0284c7",
      "binding": null
    },
    "operation_error": {
      "name": "操作错误",
      "description": "页面操作器拒绝请求时返回的结构化错误。",
      "type": "json",
      "value": {},
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_page_operator",
        "nodeId": "execute_page_operation",
        "fieldKey": "error",
        "managed": true
      }
    },
    "operation_result": {
      "name": "前端操作结果",
      "description": "前端执行虚拟 UI 操作后的确认结果，包含前后路由、快照、触发 run 和错误。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "goal_review": {
      "name": "目标验证",
      "description": "目标是否完成、是否继续操作、是否需要澄清或失败收束的结构化判断。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "loop_trace": {
      "name": "循环轨迹",
      "description": "已尝试页面操作和验证结果的紧凑摘要列表。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": null
    },
    "public_response": {
      "name": "最终回复",
      "description": "面向用户展示的页面操作结果。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "operation_report": {
      "name": "操作报告",
      "description": "供运行详情展示的结构化路由、图、run、操作和验证摘要。",
      "type": "json",
      "value": {},
      "color": "#7c2d12",
      "binding": null
    }
  },
  "nodes": {
    "input_user_goal": {
      "kind": "input",
      "name": "输入用户目标",
      "description": "提供要完成的页面操作目标。",
      "ui": {
        "position": {
          "x": 80,
          "y": 280
        },
        "collapsed": false
      },
      "reads": [],
      "writes": [
        {
          "state": "user_goal",
          "mode": "replace"
        }
      ],
      "config": {
        "value": "打开运行记录",
        "boundaryType": "text"
      }
    },
    "execute_page_operation": {
      "kind": "agent",
      "name": "执行页面操作",
      "description": "读取页面操作器注入的当前页面操作书，直接选择并请求一次必要页面操作。",
      "ui": {
        "position": {
          "x": 620,
          "y": 280
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "user_goal",
          "required": true,
          "binding": {
            "kind": "action_input",
            "actionKey": "toograph_page_operator",
            "fieldKey": "user_goal",
            "managed": true
          }
        },
        {
          "state": "operation_result",
          "required": false
        },
        {
          "state": "goal_review",
          "required": false
        },
        {
          "state": "loop_trace",
          "required": false
        }
      ],
      "writes": [
        {
          "state": "operation_error",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "toograph_page_operator",
        "actionBindings": [
          {
            "actionKey": "toograph_page_operator",
            "outputMapping": {
              "error": "operation_error"
            }
          }
        ],
        "actionInstructionBlocks": {
          "toograph_page_operator": {
            "actionKey": "toograph_page_operator",
            "title": "页面操作器 action instruction",
            "content": "你已绑定 TooGraph 页面操作器。本节点只调用一次 toograph_page_operator。本节点是页面操作的唯一决策点：先读取 Action 注入的当前页面操作书和 available_commands，再结合 user_goal、上一轮 operation_result、goal_review、loop_trace 直接输出本轮 Action 参数。需要运行指定图模板时只输出 template_target、cursor_lifecycle、reason；template_target 包含 template_id、template_name、search_text、input_text，input_text 通常直接使用 user_goal。普通页面操作只输出一条来自当前页面操作书的 commands。需要编辑当前图时只使用 graph_edit editor.graph.playback，并给出语义 graph_edit_intents。不要输出 DOM selector、坐标、截图、未列出的页面目标或多步计划。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只调用一次 toograph_page_operator。它必须在读取页面操作书后直接决定本轮操作：运行模板时输出 template_target；普通页面操作只从当前页面操作书选择一条 click、focus、clear、type、press 或 wait；图编辑只使用 graph_edit editor.graph.playback 和语义 graph_edit_intents。可以参考 operation_result、goal_review、loop_trace 避免重复尝试。不要在本节点总结结果，前端执行后会恢复并进入验证节点。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.1
      }
    },
    "verify_goal_against_refreshed_context": {
      "kind": "agent",
      "name": "验证刷新后的页面目标",
      "description": "根据前端恢复后的结构化页面事实和操作结果判断目标是否完成。",
      "ui": {
        "position": {
          "x": 1160,
          "y": 280
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "user_goal",
          "required": true
        },
        {
          "state": "page_operation_context",
          "required": true
        },
        {
          "state": "operation_error",
          "required": false
        },
        {
          "state": "operation_result",
          "required": true
        },
        {
          "state": "loop_trace",
          "required": false
        }
      ],
      "writes": [
        {
          "state": "goal_review",
          "mode": "replace"
        },
        {
          "state": "loop_trace",
          "mode": "replace"
        },
        {
          "state": "operation_report",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "使用 user_goal、page_operation_context.page_facts、operation_result 和 operation_error 验证用户目标。goal_review 必须是 JSON 对象，包含 goal_completed(boolean)、needs_more_operations(boolean)、needs_clarification(boolean)、failure_reason、next_requirement、evidence。只有最新页面事实或 operation_result 明确满足 user_goal 时才把 goal_completed 设为 true。运行图目标必须看到 operation_result.triggered_run_id 且 triggered_run_status 为 completed、failed 或 cancelled；若 triggered_run_status 仍是 queued/running/resuming/awaiting_human，则 needs_more_operations 设为 true。失败时优先使用 canonical failure_reason：target_graph_not_found、run_record_not_found、stale_page_snapshot、destructive_operation_blocked、triggered_run_failed、operation_interrupted。关注 operation_result.operation_request_id、status、triggered_run_status、triggered_run_id、triggered_graph_id、route_after、page_snapshot_after、page_facts.activeGraph 和 graph_edit_summary。operation_report 写紧凑对象，包含 operation_result.operation_request_id、status、route_before、route_after、target_id、triggered_run_id、triggered_run_status、graph_edit_summary、goal_completed、failure_reason。loop_trace 写追加后的紧凑数组。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.1
      }
    },
    "continue_operation_loop": {
      "kind": "condition",
      "name": "继续页面操作?",
      "description": "目标未完成且仍可继续时回到规划节点；达到上限时输出失败或待澄清结果。",
      "ui": {
        "position": {
          "x": 1700,
          "y": 320
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "goal_review",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 6,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.goal_review.needs_more_operations",
          "operator": "==",
          "value": true
        }
      }
    },
    "draft_public_response": {
      "kind": "agent",
      "name": "起草最终回复",
      "description": "根据目标验证和操作报告生成用户可见结果。",
      "ui": {
        "position": {
          "x": 2320,
          "y": 280
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "user_goal",
          "required": true
        },
        {
          "state": "goal_review",
          "required": true
        },
        {
          "state": "operation_result",
          "required": false
        },
        {
          "state": "operation_report",
          "required": false
        },
        {
          "state": "loop_trace",
          "required": false
        }
      ],
      "writes": [
        {
          "state": "public_response",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "生成最终用户回复。只有 goal_review.goal_completed 为 true 时才说明已完成，并包含可用的 route、graph id/name、run id、触发 run 终态或保存结果。若 needs_clarification 为 true，明确需要用户补充什么。若失败，按 goal_review.failure_reason 简洁说明失败原因：target_graph_not_found=找不到目标图；run_record_not_found=找不到匹配运行记录；stale_page_snapshot=页面快照过期；destructive_operation_blocked=破坏性操作被阻止；triggered_run_failed=触发的 run 失败；operation_interrupted=操作被用户或运行时中断。不要声称只是发出请求就完成。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.2
      }
    },
    "output_public_response": {
      "kind": "output",
      "name": "输出最终回复",
      "description": "展示页面操作工作流的最终回复。",
      "ui": {
        "position": {
          "x": 2840,
          "y": 120
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "public_response",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "markdown",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_operation_report": {
      "kind": "output",
      "name": "输出操作报告",
      "description": "展示结构化页面操作报告，供运行详情审计。",
      "ui": {
        "position": {
          "x": 2840,
          "y": 540
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "operation_report",
          "required": false
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_user_goal",
      "target": "execute_page_operation"
    },
    {
      "source": "execute_page_operation",
      "target": "verify_goal_against_refreshed_context"
    },
    {
      "source": "verify_goal_against_refreshed_context",
      "target": "continue_operation_loop"
    },
    {
      "source": "draft_public_response",
      "target": "output_public_response"
    },
    {
      "source": "draft_public_response",
      "target": "output_operation_report"
    }
  ],
  "conditional_edges": [
    {
      "source": "continue_operation_loop",
      "branches": {
        "true": "execute_page_operation",
        "false": "draft_public_response",
        "exhausted": "draft_public_response"
      }
    }
  ],
  "metadata": {
    "graphProtocol": "node_system",
    "role": "page_operation_workflow",
    "pageOperationTemplate": true,
    "capabilityDiscoverableDefault": false,
    "outputContract": [
      {
        "key": "public_response",
        "name": "最终回复",
        "description": "页面操作目标完成或终态失败后的用户可见回复。",
        "type": "markdown",
        "role": "final_response",
        "passThrough": true,
        "required": true
      },
      {
        "key": "operation_report",
        "name": "操作报告",
        "description": "页面操作、触发 run、失败分类、retry chain 和 artifacts 的结构化证据。",
        "type": "json",
        "role": "evidence",
        "passThrough": false,
        "required": false
      }
    ],
    "targetFlows": [
      {
        "id": "open_runs_page",
        "sampleGoal": "打开运行记录",
        "operationTargets": [
          "app.nav.runs",
          "runs.action.refresh"
        ],
        "completionEvidence": [
          "page_facts.route.path == /runs",
          "visibleRuns contains run cards"
        ]
      },
      {
        "id": "open_run_detail",
        "sampleGoal": "打开某个运行详情",
        "operationTargets": [
          "app.nav.runs",
          "runs.search.graphName",
          "runs.run.<runId>.openDetail"
        ],
        "completionEvidence": [
          "page_facts.route.path starts with /runs/",
          "visible run detail matches requested run id"
        ]
      },
      {
        "id": "open_library_page",
        "sampleGoal": "打开图与模板页面",
        "operationTargets": [
          "app.nav.library",
          "library.search.query"
        ],
        "completionEvidence": [
          "page_facts.route.path == /library",
          "visibleGraphs or visibleTemplates are available"
        ]
      },
      {
        "id": "create_blank_graph",
        "sampleGoal": "新建一个空白图",
        "operationTargets": [
          "app.nav.library",
          "library.action.newBlankGraph",
          "editor.launcher.createNew"
        ],
        "completionEvidence": [
          "page_facts.route.path starts with /editor",
          "page_facts.activeGraph exists",
          "active graph is dirty or unnamed draft"
        ]
      },
      {
        "id": "open_named_graph",
        "sampleGoal": "打开名为 X 的图",
        "operationTargets": [
          "app.nav.library",
          "library.search.query",
          "library.graph.<graphId>.open",
          "editor.launcher.openGraph.<graphId>"
        ],
        "completionEvidence": [
          "page_facts.activeGraph.name matches target",
          "page_facts.activeGraph.graphId matches visible graph id"
        ]
      },
      {
        "id": "run_named_template",
        "sampleGoal": "运行名为 X 的图模板并拿取结果",
        "operationTargets": [
          "template_target",
          "app.nav.library",
          "library.search.query",
          "library.template.<templateId>.open",
          "editor.canvas.node.<inputNodeId>.input.value",
          "editor.action.runActiveGraph"
        ],
        "completionEvidence": [
          "operation_result.commands includes run_template",
          "operation_result.input_text matches user_goal",
          "triggered_run_id present",
          "triggered_run_status terminal",
          "page_facts.latestForegroundRun.runId matches triggered_run_id"
        ]
      },
      {
        "id": "run_current_graph",
        "sampleGoal": "运行当前图并告诉我结果",
        "operationTargets": [
          "editor.action.runActiveGraph",
          "editor.action.toggleRunActivity"
        ],
        "completionEvidence": [
          "triggered_run_id present",
          "triggered_run_status terminal",
          "page_facts.latestForegroundRun.runId matches triggered_run_id"
        ]
      },
      {
        "id": "create_basic_llm_graph",
        "sampleGoal": "新建一个包含输入、LLM、输出的图",
        "operationTargets": [
          "app.nav.library",
          "library.action.newBlankGraph",
          "editor.graph.playback",
          "editor.action.saveActiveGraph"
        ],
        "completionEvidence": [
          "graph_edit_summary.applied is true",
          "page_facts.activeGraph exists",
          "node labels include input, LLM, output"
        ]
      },
      {
        "id": "rename_current_node",
        "sampleGoal": "编辑当前图，给某个节点改名",
        "operationTargets": [
          "editor.canvas.node.<nodeId>",
          "editor.graph.playback",
          "editor.action.saveActiveGraph"
        ],
        "completionEvidence": [
          "graph_edit_summary.applied is true",
          "page_facts.activeGraph.dirty or saved revision updated",
          "target node label changed"
        ]
      }
    ],
    "failureGuidance": {
      "target_graph_not_found": {
        "failureReason": "target_graph_not_found",
        "replyGuidance": "说明没有找到目标图，请用户确认图名称或先打开目标图。",
        "evidence": [
          "page_facts.visibleGraphs",
          "page_facts.activeGraph",
          "user_goal"
        ]
      },
      "run_record_not_found": {
        "failureReason": "run_record_not_found",
        "replyGuidance": "说明没有找到匹配的运行记录，请用户提供 run id 或更明确的图名称。",
        "evidence": [
          "page_facts.visibleRuns",
          "operation_result.triggered_run_id",
          "user_goal"
        ]
      },
      "stale_page_snapshot": {
        "failureReason": "stale_page_snapshot",
        "replyGuidance": "说明当前页面快照已过期，需要刷新页面上下文后再继续。",
        "evidence": [
          "operation_result.page_snapshot_after",
          "page_operation_context.page_snapshot",
          "operation_result.operation_request_id"
        ]
      },
      "destructive_operation_blocked": {
        "failureReason": "destructive_operation_blocked",
        "replyGuidance": "说明目标属于破坏性或需确认操作，页面操作器已阻止执行。",
        "evidence": [
          "operation_error.code",
          "operation_result.error"
        ]
      },
      "triggered_run_failed": {
        "failureReason": "triggered_run_failed",
        "replyGuidance": "说明已触发运行但 run 以失败终态结束，并给出 run id。",
        "evidence": [
          "operation_result.triggered_run_id",
          "operation_result.triggered_run_status",
          "page_facts.latestForegroundRun"
        ]
      },
      "operation_interrupted": {
        "failureReason": "operation_interrupted",
        "replyGuidance": "说明页面操作被用户、运行时或前端流程中断，未完成目标。",
        "evidence": [
          "operation_result.status",
          "operation_result.error",
          "operation_error.code"
        ]
      }
    }
  }
}
