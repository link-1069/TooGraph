                { "state": "operation_request_id", "mode": "replace" },
                { "state": "operation_journal", "mode": "replace" },
                { "state": "operation_error", "mode": "replace" }
              ],
              "config": {
                "skillKey": "toograph_page_operator",
                "skillBindings": [
                  {
                    "skillKey": "toograph_page_operator",
