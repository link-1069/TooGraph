                      "operation_request_id": "operation_request_id",
                      "journal": "operation_journal",
                      "error": "operation_error"
                    }
                  }
                ],
                "skillInstructionBlocks": {
                  "toograph_page_operator": {
                    "skillKey": "toograph_page_operator",
                    "title": "页面操作器 skill instruction",
                    "content": "你已绑定 TooGraph 页面操作器。本节点只调用一次 toograph_page_operator。若 operation_request.semantic_intent 是 run_template 或包含 target_template_id/target_template_name，直接输出 template_target 对象，包含 template_id、template_name、search_text、input_text；input_text 必须是本次要写入目标模板 input 节点的目标文本，通常直接使用 user_goal。不要把打开图库、搜索、点开模板、写 input、运行拆成 commands。其他普通页面操作才根据 operation_request 和当前页面操作书输出一条合法 commands；如果 operation_request.command 为空或 blocked_reason 非空，优先选择安全 wait short 或返回不可执行原因。不要输出 DOM selector、坐标、截图、伙伴自表面目标或多步计划。",
                    "source": "node.override"
                  }
                },
                "taskInstruction": "本节点只调用一次 toograph_page_operator，并把 operation_request 转成该 Skill 的结构化输出。运行指定图模板时只输出 template_target，让 Skill/frontend 程序化执行打开图与模板、搜索目标模板、点开模板、把本次目标写入 input 节点、运行并等待结果。普通操作只能选择当前页面操作书中的 click、focus、clear、type、press 或 wait；图编辑只能使用 graph_edit editor.graph.playback 和语义 graph_edit_intents。不要在本节点总结结果，前端执行后会恢复并进入验证节点。",
                "modelSource": "global",
                "model": "",
                "thinkingMode": "high",
                "temperature": 0.1
              }
            },
            "verify_goal_against_refreshed_context": {
              "kind": "agent",
              "name": "验证刷新后的页面目标",
              "description": "读取前端恢复写入的操作结果和最新页面上下文，判断目标是否真正完成。",
              "ui": { "position": { "x": 1400, "y": 460 }, "collapsed": false },
              "reads": [
                { "state": "user_goal", "required": true },
                { "state": "page_context", "required": true },
                { "state": "page_operation_context", "required": true },
                { "state": "goal_plan", "required": true },
                { "state": "operation_request", "required": true },
                { "state": "operation_ok", "required": true },
                { "state": "operation_request_id", "required": false },
                { "state": "operation_journal", "required": false },
                { "state": "operation_error", "required": false },
                { "state": "operation_result", "required": true },
                { "state": "loop_trace", "required": false }
              ],
              "writes": [
                { "state": "page_snapshot", "mode": "replace" },
                { "state": "goal_review", "mode": "replace" },
                { "state": "loop_trace", "mode": "replace" },
                { "state": "operation_report", "mode": "replace" }
              ],
              "config": {
                "skillKey": "",
                "skillBindings": [],
                "skillInstructionBlocks": {},
                "taskInstruction": "使用 page_operation_context.page_facts、operation_result 和 goal_plan 验证用户目标。goal_review 必须是 JSON 对象，包含 goal_completed(boolean)、needs_more_operations(boolean)、needs_clarification(boolean)、failure_reason、next_requirement、evidence。只有最新页面事实或 operation_result 明确匹配 success_criteria 时才把 goal_completed 设为 true。运行图目标必须看到 operation_result.triggered_run_id 且 triggered_run_status 为 completed、failed 或 cancelled；若 triggered_run_status 仍是 queued/running/resuming/awaiting_human，则 needs_more_operations 设为 true。失败时优先使用 canonical failure_reason：target_graph_not_found、run_record_not_found、stale_page_snapshot、destructive_operation_blocked、triggered_run_failed、operation_interrupted。关注 triggered_run_status、triggered_run_id、triggered_graph_id、route_after、page_snapshot_after、page_facts.activeGraph 和 graph_edit_summary。page_snapshot 写 operation_result.page_snapshot_after 或 page_operation_context.page_snapshot。operation_report 写紧凑对象，包含 operation_request_id、status、route_before、route_after、target_id、triggered_run_id、triggered_run_status、graph_edit_summary、goal_completed、failure_reason。loop_trace 写追加后的紧凑数组。",
                "modelSource": "global",
                "model": "",
                "thinkingMode": "high",
                "temperature": 0.1
              }
            },
