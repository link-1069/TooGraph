              "ui": { "position": { "x": 480, "y": 460 }, "collapsed": false },
              "reads": [
                { "state": "user_goal", "required": true },
                { "state": "goal_plan", "required": true },
                { "state": "operation_result", "required": false },
                { "state": "goal_review", "required": false },
                { "state": "loop_trace", "required": false }
