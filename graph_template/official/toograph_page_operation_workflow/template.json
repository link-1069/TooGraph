{
  "template_id": "toograph_page_operation_workflow",
  "label": "操作 TooGraph 页面",
  "description": "解析用户页面操作目标，通过 TooGraph 页面操作器执行一次可见 UI 操作，等待前端确认并用刷新后的页面上下文验证目标，必要时循环，最终只在目标完成或明确终态失败后回复。",
  "default_graph_name": "操作 TooGraph 页面",
  "state_schema": {
    "user_goal": {
      "name": "用户目标",
      "description": "用户希望 TooGraph 当前页面完成的具体目标。",
      "type": "text",
      "value": "打开运行记录",
      "color": "#d97706",
      "binding": null
    },
    "page_context": {
      "name": "页面上下文",
      "description": "当前页面、可见目标和近期操作的可读摘要。",
      "type": "markdown",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "page_operation_context": {
      "name": "页面操作上下文",
      "description": "结构化页面操作书、页面快照和页面事实，由前端在运行或恢复时注入。",
      "type": "json",
      "value": {},
      "color": "#0284c7",
      "binding": null
    },
    "goal_plan": {
      "name": "目标计划",
      "description": "目标类型、目标对象线索、副作用、成功标准和停止条件。",
      "type": "json",
      "value": {},
      "color": "#16a34a",
      "binding": null
    },
    "operation_request": {
      "name": "下一步操作请求",
      "description": "本轮计划交给页面操作器的目标、命令候选和验证预期。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "operation_ok": {
      "name": "操作请求已接受",
      "description": "页面操作器是否接受本轮语义操作请求。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_page_operator",
        "nodeId": "execute_page_operation",
        "fieldKey": "ok",
        "managed": true
      }
    },
    "operation_request_id": {
      "name": "操作请求 ID",
      "description": "页面操作器生成的稳定请求 ID，用于关联 activity event、前端执行确认和自动恢复。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_page_operator",
        "nodeId": "execute_page_operation",
        "fieldKey": "operation_request_id",
        "managed": true
      }
    },
    "operation_journal": {
      "name": "操作日志",
      "description": "页面操作器返回的请求日志和校验摘要。",
      "type": "json",
      "value": {},
      "color": "#4f46e5",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_page_operator",
        "nodeId": "execute_page_operation",
        "fieldKey": "journal",
        "managed": true
      }
    },
    "operation_error": {
      "name": "操作错误",
      "description": "页面操作器拒绝请求时返回的结构化错误。",
      "type": "json",
      "value": {},
      "color": "#dc2626",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_page_operator",
        "nodeId": "execute_page_operation",
        "fieldKey": "error",
        "managed": true
      }
    },
    "operation_result": {
      "name": "前端操作结果",
      "description": "前端执行虚拟 UI 操作后的确认结果，包含前后路由、快照、触发 run 和错误。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "page_snapshot": {
      "name": "页面快照",
      "description": "最新页面快照，用于验证路由、活跃图、可见卡片和运行状态。",
      "type": "json",
      "value": {},
      "color": "#0891b2",
      "binding": null
    },
    "goal_review": {
      "name": "目标验证",
      "description": "目标是否完成、是否继续操作、是否需要澄清或失败收束的结构化判断。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "loop_trace": {
      "name": "循环轨迹",
      "description": "已尝试页面操作和验证结果的紧凑摘要列表。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": null
    },
    "final_reply": {
      "name": "最终回复",
      "description": "面向用户展示的页面操作结果。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "operation_report": {
      "name": "操作报告",
      "description": "供运行详情展示的结构化路由、图、run、操作和验证摘要。",
      "type": "json",
      "value": {},
      "color": "#7c2d12",
      "binding": null
    }
  },
