        {
          "state": "capability_selection_audit",
          "mode": "replace"
        }
      ],
      "config": {
        "skillKey": "toograph_capability_selector",
        "skillBindings": [
          {
            "skillKey": "toograph_capability_selector",
            "outputMapping": {
              "capability": "selected_capability",
              "found": "capability_found",
              "audit": "capability_selection_audit"
            }
          }
        ],
        "skillInstructionBlocks": {
          "toograph_capability_selector": {
            "skillKey": "toograph_capability_selector",
            "title": "能力选择 skill instruction",
            "content": "根据 request_understanding 和 user_message 从候选清单中选择一个启用能力。优先图模板，其次 Skill；不要选择 buddy_autonomous_loop 自身；如果用户请求可以直接回答或没有合适能力，选择 {\"kind\":\"none\"}。",
            "source": "node.override"
          }
        },
        "taskInstruction": "选择一个能完成当前请求的能力。能力必须是单个 capability(kind=skill|subgraph|none)，不能输出能力列表。\n不要把本伙伴循环模板自身作为候选答案。若 capability_review 表示需要继续调用另一个能力，则以 capability_review.next_requirement 为当前需求。\n只选择能力，不执行能力，也不生成最终回复；执行由下游节点和运行时完成。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.1
      }
    },
    "capability_found_condition": {
      "kind": "condition",
      "name": "找到能力?",
      "description": "没有合适能力时进入缺失能力复盘。",
      "ui": {
        "position": {
          "x": 810,
          "y": 360
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "capability_found",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 3,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.capability_found",
          "operator": "==",
          "value": true
        }
      }
    },
    "selected_capability_is_subgraph": {
      "kind": "condition",
