    "review_capability_result": {
      "kind": "agent",
      "name": "复盘能力结果",
      "description": "判断能力结果是否足够，是否还需要调用另一个能力。",
      "ui": {
        "position": {
          "x": 4172,
          "y": 720
        },
        "collapsed": false
