{
  "template_id": "knowledge_document_chunking_demo",
  "label": "知识库文档切片示例",
  "description": "Demo: chunk normalized knowledge documents with source_chunker, then write chunk candidates into unified retrieval_documents / retrieval_chunks. Fill embedding_model_refs on the ingestion tool card when embeddings should be queued.",
  "default_graph_name": "知识库文档切片示例",
  "state_schema": {
    "document_source": {
      "name": "Document Source",
      "description": "规范化文档包。后续可以由文件夹读取和文档规范化 Tool 产出，这里用示例 JSON 说明输入形状。",
      "type": "json",
      "value": {
        "documents": [
          {
            "document_id": "doc_embedding_design",
            "title": "Embedding 设计示例",
            "source_path": "docs/embedding-design.md",
            "mime_type": "text/markdown",
            "content": "# Embedding 设计示例\n\n原始材料层负责保留可追溯的输入来源。\n\n切片层把规范化材料转换成 chunk candidates。\n\n入库层再把 chunk candidates 写入检索存储，并显式排 embedding job。"
          }
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "chunks": {
      "name": "Chunks",
      "description": "文档切片候选；这里只展示结果，不写入检索库。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "chunks",
        "managed": true
      }
    },
    "ingestion_report": {
      "name": "Ingestion Report",
      "description": "Report returned by retrieval_ingestion_writer.",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "retrieval_ingestion_writer",
        "nodeId": "write_retrieval_ingestion",
        "fieldKey": "ingestion_report",
        "managed": true
      }
    },
    "indexed_chunks": {
      "name": "Indexed Chunks",
      "description": "Chunk records written into unified retrieval_chunks.",
      "type": "json",
      "value": [],
      "color": "#0891b2",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "retrieval_ingestion_writer",
        "nodeId": "write_retrieval_ingestion",
        "fieldKey": "indexed_chunks",
        "managed": true
      }
    },
    "embedding_jobs": {
      "name": "Embedding Jobs",
      "description": "Embedding jobs queued by embedding_model_refs configured on the ingestion tool card.",
      "type": "json",
      "value": [],
      "color": "#d97706",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "retrieval_ingestion_writer",
        "nodeId": "write_retrieval_ingestion",
        "fieldKey": "embedding_jobs",
        "managed": true
      }
    }
  },
  "nodes": {
    "input_document_source": {
      "kind": "input",
      "name": "Document Source",
      "description": "把 documents 数组作为 source_chunker 的 source 字段。",
      "ui": {
        "position": {
          "x": 80,
          "y": 420
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 260
        }
      },
      "reads": [],
      "writes": [
        {
          "state": "document_source",
          "mode": "replace"
        }
      ],
      "config": {
        "value": {
          "documents": [
            {
              "document_id": "doc_embedding_design",
              "title": "Embedding 设计示例",
              "source_path": "docs/embedding-design.md",
              "mime_type": "text/markdown",
              "content": "# Embedding 设计示例\n\n原始材料层负责保留可追溯的输入来源。\n\n切片层把规范化材料转换成 chunk candidates。\n\n入库层再把 chunk candidates 写入检索存储，并显式排 embedding job。"
            }
          ]
        },
        "boundaryType": "json"
      }
    },
    "chunk_source_material": {
      "kind": "tool",
      "name": "Run Source Chunker",
      "description": "调用 source_chunker：source_kind、strategy 和 limits 存在 Tool 卡片内，图上只连接 source。",
      "ui": {
        "position": {
          "x": 620,
          "y": 360
        },
        "collapsed": false,
        "size": {
          "width": 500,
          "height": 430
        }
      },
      "reads": [
        {
          "state": "document_source",
          "required": true,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "source_chunker",
            "fieldKey": "source",
            "managed": true
          }
        }
      ],
      "writes": [
        {
          "state": "chunks",
          "mode": "replace"
        }
      ],
      "config": {
        "toolKey": "source_chunker",
        "staticInputs": {
          "source_kind": "normalized_documents",
          "strategy": "document_section_window",
          "limits": {
            "max_chars": 600,
            "overlap_chars": 80
          }
        }
      }
    },
    "output_chunks": {
      "kind": "output",
      "name": "Chunks",
      "description": "查看 source_chunker 生成的文档 chunk candidates。",
      "ui": {
        "position": {
          "x": 1840,
          "y": 180
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "chunks",
          "required": true,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "write_retrieval_ingestion": {
      "kind": "tool",
      "name": "Write Retrieval Ingestion",
      "description": "Write chunk candidates into retrieval_documents and retrieval_chunks, and optionally queue embedding jobs.",
      "ui": {
        "position": {
          "x": 1240,
          "y": 320
        },
        "collapsed": false,
        "size": {
          "width": 520,
          "height": 500
        }
      },
      "reads": [
        {
          "state": "document_source",
          "required": true,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "retrieval_ingestion_writer",
            "fieldKey": "source",
            "managed": true
          }
        },
        {
          "state": "chunks",
          "required": true,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "retrieval_ingestion_writer",
            "fieldKey": "chunks",
            "managed": true
          }
        }
      ],
      "writes": [
        {
          "state": "ingestion_report",
          "mode": "replace"
        },
        {
          "state": "indexed_chunks",
          "mode": "replace"
        },
        {
          "state": "embedding_jobs",
          "mode": "replace"
        }
      ],
      "config": {
        "toolKey": "retrieval_ingestion_writer",
        "staticInputs": {
          "source_kind": "knowledge_document",
          "embedding_model_refs": "",
          "scope": {
            "collection": "knowledge_document_demo"
          },
          "metadata": {
            "template_id": "knowledge_document_chunking_demo",
            "role": "knowledge_document_chunking_demo"
          }
        }
      }
    },
    "output_ingestion_report": {
      "kind": "output",
      "name": "Ingestion Report",
      "description": "Inspect retrieval ingestion counts, written chunks, and queued embedding jobs.",
      "ui": {
        "position": {
          "x": 1840,
          "y": 560
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 300
        }
      },
      "reads": [
        {
          "state": "ingestion_report",
          "required": true,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_document_source",
      "target": "chunk_source_material"
    },
    {
      "source": "chunk_source_material",
      "target": "write_retrieval_ingestion"
    },
    {
      "source": "chunk_source_material",
      "target": "output_chunks"
    },
    {
      "source": "write_retrieval_ingestion",
      "target": "output_ingestion_report"
    }
  ],
  "conditional_edges": [],
  "metadata": {
    "graphProtocol": "node_system",
    "origin": "embedding",
    "role": "knowledge_document_chunking_demo",
    "capabilityDiscoverableDefault": false,
    "requiredTools": [
      "source_chunker",
      "retrieval_ingestion_writer"
    ],
    "permissions": [],
    "exampleOnly": true,
    "outputContract": [
      {
        "state": "chunks",
        "role": "chunk_candidates",
        "label": "Knowledge document chunk candidates"
      },
      {
        "state": "ingestion_report",
        "role": "retrieval_ingestion_report",
        "label": "Knowledge document retrieval ingestion"
      },
      {
        "state": "indexed_chunks",
        "role": "retrieval_chunks",
        "label": "Indexed retrieval chunks"
      },
      {
        "state": "embedding_jobs",
        "role": "embedding_jobs",
        "label": "Queued embedding jobs"
      }
    ]
  }
}
