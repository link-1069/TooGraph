{
  "template_id": "knowledge_document_chunking_demo",
  "label": "知识库文档切片示例",
  "description": "演示如何把规范化知识库文档包连接到 source_chunker，生成可检查的文档 chunk candidates；不写库、不排 embedding job。",
  "default_graph_name": "知识库文档切片示例",
  "state_schema": {
    "document_source": {
      "name": "Document Source",
      "description": "规范化文档包。后续可以由文件夹读取和文档规范化 Tool 产出，这里用示例 JSON 说明输入形状。",
      "type": "json",
      "value": {
        "documents": [
          {
            "document_id": "doc_embedding_design",
            "title": "Embedding 设计示例",
            "source_path": "docs/embedding-design.md",
            "mime_type": "text/markdown",
            "content": "# Embedding 设计示例\n\n原始材料层负责保留可追溯的输入来源。\n\n切片层把规范化材料转换成 chunk candidates。\n\n入库层再把 chunk candidates 写入检索存储，并显式排 embedding job。"
          }
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "chunker_status": {
      "name": "Chunker Status",
      "description": "source_chunker 返回的执行状态。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "status",
        "managed": true
      }
    },
    "chunk_count": {
      "name": "Chunk Count",
      "description": "生成的 chunk candidates 数量。",
      "type": "number",
      "value": 0,
      "color": "#16a34a",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "chunk_count",
        "managed": true
      }
    },
    "chunks": {
      "name": "Chunks",
      "description": "文档切片候选；这里只展示结果，不写入检索库。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "chunks",
        "managed": true
      }
    },
    "chunk_report": {
      "name": "Chunk Report",
      "description": "切片审计报告，包含文档数和限制参数。",
      "type": "json",
      "value": {},
      "color": "#0369a1",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "report",
        "managed": true
      }
    },
    "chunk_error": {
      "name": "Chunk Error",
      "description": "切片失败时的错误信息。",
      "type": "text",
      "value": "",
      "color": "#dc2626",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "source_chunker",
        "nodeId": "chunk_source_material",
        "fieldKey": "error",
        "managed": true
      }
    }
  },
  "nodes": {
    "input_document_source": {
      "kind": "input",
      "name": "Document Source",
      "description": "把 documents 数组作为 source_chunker 的 source 字段。",
      "ui": {
        "position": {
          "x": 80,
          "y": 420
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 260
        }
      },
      "reads": [],
      "writes": [
        {
          "state": "document_source",
          "mode": "replace"
        }
      ],
      "config": {
        "value": {
          "documents": [
            {
              "document_id": "doc_embedding_design",
              "title": "Embedding 设计示例",
              "source_path": "docs/embedding-design.md",
              "mime_type": "text/markdown",
              "content": "# Embedding 设计示例\n\n原始材料层负责保留可追溯的输入来源。\n\n切片层把规范化材料转换成 chunk candidates。\n\n入库层再把 chunk candidates 写入检索存储，并显式排 embedding job。"
            }
          ]
        },
        "boundaryType": "json"
      }
    },
    "chunk_source_material": {
      "kind": "tool",
      "name": "Run Source Chunker",
      "description": "调用 source_chunker：source_kind、strategy 和 limits 存在 Tool 卡片内，图上只连接 source。",
      "ui": {
        "position": {
          "x": 620,
          "y": 360
        },
        "collapsed": false,
        "size": {
          "width": 500,
          "height": 560
        }
      },
      "reads": [
        {
          "state": "document_source",
          "required": true,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "source_chunker",
            "fieldKey": "source",
            "managed": true
          }
        }
      ],
      "writes": [
        {
          "state": "chunker_status",
          "mode": "replace"
        },
        {
          "state": "chunk_count",
          "mode": "replace"
        },
        {
          "state": "chunks",
          "mode": "replace"
        },
        {
          "state": "chunk_report",
          "mode": "replace"
        },
        {
          "state": "chunk_error",
          "mode": "replace"
        }
      ],
      "config": {
        "toolKey": "source_chunker",
        "staticInputs": {
          "source_kind": "normalized_documents",
          "strategy": "document_section_window",
          "limits": {
            "max_chars": 600,
            "overlap_chars": 80
          }
        }
      }
    },
    "output_chunks": {
      "kind": "output",
      "name": "Chunks",
      "description": "查看 source_chunker 生成的文档 chunk candidates。",
      "ui": {
        "position": {
          "x": 1240,
          "y": 240
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "chunks",
          "required": true,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_report": {
      "kind": "output",
      "name": "Chunk Report",
      "description": "查看切片数量、文档数量和切片限制。",
      "ui": {
        "position": {
          "x": 1240,
          "y": 640
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "chunk_report",
          "required": false,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_document_source",
      "target": "chunk_source_material"
    },
    {
      "source": "chunk_source_material",
      "target": "output_chunks"
    },
    {
      "source": "chunk_source_material",
      "target": "output_report"
    }
  ],
  "conditional_edges": [],
  "metadata": {
    "graphProtocol": "node_system",
    "origin": "embedding",
    "role": "knowledge_document_chunking_demo",
    "capabilityDiscoverableDefault": false,
    "requiredTools": [
      "source_chunker"
    ],
    "permissions": [],
    "exampleOnly": true,
    "outputContract": [
      {
        "state": "chunks",
        "role": "chunk_candidates",
        "label": "Knowledge document chunk candidates"
      },
      {
        "state": "chunk_report",
        "role": "audit",
        "label": "Chunking report"
      }
    ]
  }
}
