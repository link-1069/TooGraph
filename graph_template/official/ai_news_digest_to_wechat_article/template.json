      }
    },
    "prepare_content_memory": {
      "kind": "agent",
      "name": "准备内容偏好召回",
      "description": "把主题和风格要求转成只读记忆召回请求。",
      "ui": {
        "position": {
          "x": 520,
          "y": 320
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 280
        }
      },
      "reads": [
        {
          "state": "topic",
          "required": true
        },
        {
          "state": "date_range",
          "required": true
        },
        {
          "state": "target_platforms",
          "required": true
        },
        {
          "state": "style_brief",
          "required": false
        }
      ],
      "writes": [
        {
          "state": "memory_request",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "生成 memory_request JSON，只用于只读召回 Buddy 历史会话中的长期偏好、历史反馈和相关上下文。字段包含 mode、query、limit、window；mode 默认 discover，limit 不超过 8，window 不超过 2。query 应结合本模板输入和用户目标，避免过宽；不要写 scope、layer、status、top_k、max_chars，不要生成业务结论。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "recall_content_memory": {
      "kind": "agent",
      "name": "召回内容偏好",
      "description": "运行 buddy_session_recall Action，只透传召回结果。",
      "ui": {
        "position": {
          "x": 1060,
          "y": 320
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 300
        }
      },
      "reads": [
        {
          "state": "state_1",
          "required": true,
          "binding": {
            "kind": "action_input",
            "actionKey": "buddy_session_recall",
            "fieldKey": "recall_request",
            "managed": true
          }
        },
        {
          "state": "memory_request",
          "required": true
        }
      ],
      "writes": [
        {
          "state": "buddy_session_recall_success",
          "mode": "replace"
        },
        {
          "state": "session_recall_context",
          "mode": "replace"
        },
        {
          "state": "recalled_sessions",
          "mode": "replace"
        },
        {
          "state": "buddy_session_recall_result",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "buddy_session_recall",
        "actionBindings": [
          {
            "actionKey": "buddy_session_recall",
            "outputMapping": {
              "success": "buddy_session_recall_success",
              "session_recall_context": "session_recall_context",
              "sessions": "recalled_sessions",
              "result": "buddy_session_recall_result"
            }
          }
        ],
        "actionInstructionBlocks": {
          "buddy_session_recall": {
            "actionKey": "buddy_session_recall",
            "title": "Buddy session recall instruction",
            "content": "根据上游记忆检索需求生成 recall_request 参数；优先使用 discover + query 搜索统一数据库中的 Buddy 会话消息。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只负责运行 buddy_session_recall。根据上游 memory_request 生成 recall_request；mode 只能是 browse、discover 或 scroll，默认 discover；limit 不超过 8，window 不超过 2。不要输出业务结论，不写 MEMORY.md，不创建逐条审批记录。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "prepare_news_fetch": {
      "kind": "agent",
      "name": "准备新闻获取",
      "description": "整理粘贴材料和可选联网补充计划。",
      "ui": {
        "position": {
          "x": 1600,
          "y": 320
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 300
        }
      },
      "reads": [
        {
          "state": "topic",
          "required": true
        },
        {
          "state": "date_range",
          "required": true
        },
        {
          "state": "raw_news_items",
          "required": false
        },
        {
          "state": "use_web_search",
          "required": true
        },
        {
          "state": "session_recall_context",
          "required": false
        }
      ],
      "writes": [
        {
          "state": "news_fetch_plan",
          "mode": "replace"
        },
        {
          "state": "current_query",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "news_fetch_plan 写成 Markdown，说明将如何使用 raw_news_items、是否需要联网补充、新闻去重标准、来源充足标准和事实检查重点。current_query 写一条适合公开网页检索的搜索词；即使 use_web_search 为 false，也要给出可审计的候选查询词供用户后续启用。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "should_fetch_news": {
      "kind": "condition",
      "name": "是否联网补充",
      "description": "use_web_search 为 true 时运行 web_search，否则直接处理粘贴或 mock 材料。",
      "ui": {
        "position": {
          "x": 2140,
          "y": 330
        },
        "collapsed": false,
        "size": {
          "width": 560,
          "height": 260
        }
      },
      "reads": [
        {
          "state": "use_web_search",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 1,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.use_web_search",
          "operator": "==",
          "value": true
        }
      }
    },
    "run_web_search": {
      "kind": "agent",
      "name": "运行联网搜索",
      "description": "根据搜索词运行 web_search，只透传Action 输出。",
      "ui": {
        "position": {
          "x": 2820,
          "y": 140
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 300
        }
      },
      "reads": [
        {
          "state": "state_2",
