{
  "template_id": "ai_news_digest_to_wechat_article",
  "label": "AI 新闻公众号助手",
  "description": "当用户需要整理 AI 新闻、去重聚类、筛选重要事件，并生成公众号文章或多平台分发稿时使用。",
  "default_graph_name": "AI 新闻公众号助手",
  "state_schema": {
    "topic": {
      "name": "关注主题",
      "description": "新闻关注领域、关键词或受众关心的问题。",
      "type": "text",
      "value": "AI 产品与模型发布",
      "color": "#2563eb",
      "binding": null
    },
    "date_range": {
      "name": "时间范围",
      "description": "需要覆盖的新闻时间范围。",
      "type": "text",
      "value": "最近 7 天",
      "color": "#0f766e",
      "binding": null
    },
    "raw_news_items": {
      "name": "原始新闻材料",
      "description": "用户粘贴的新闻链接、摘要、原文片段或 mock 新闻材料。",
      "type": "markdown",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "use_web_search": {
      "name": "是否联网补充",
      "description": "true 时运行 web_search；false 时只使用用户粘贴或 mock 材料。",
      "type": "boolean",
      "value": false,
      "color": "#dc2626",
      "binding": null
    },
    "target_platforms": {
      "name": "目标平台",
      "description": "除公众号外需要输出的分发平台。",
      "type": "text",
      "value": "微信公众号、小红书、知乎、B站、X",
      "color": "#7c3aed",
      "binding": null
    },
    "style_brief": {
      "name": "文章风格",
      "description": "标题、语气、篇幅、受众和禁用表达等风格要求。",
      "type": "markdown",
      "value": "面向 AI 产品经理和技术创业者，语气克制，不夸大，不写营销腔。",
      "color": "#4f46e5",
      "binding": null
    },
    "memory_request": {
      "name": "内容偏好记忆请求",
      "description": "面向 buddy_session_recall Action 的只读召回请求。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "buddy_session_recall_success": {
      "name": "记忆召回成功",
      "description": "buddy_session_recall 是否成功。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_content_memory",
        "fieldKey": "success",
        "managed": true
      }
    },
    "omitted_memories": {
      "name": "省略记忆",
      "description": "因预算或过滤未纳入的记忆摘要。",
      "type": "json",
      "value": [],
      "color": "#a855f7",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_content_memory",
        "fieldKey": "omitted_memories",
        "managed": true
      }
    },
    "buddy_session_recall_result": {
      "name": "记忆召回摘要",
      "description": "buddy_session_recall 返回的召回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#6d28d9",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_content_memory",
        "fieldKey": "result",
        "managed": true
      }
    },
    "news_fetch_plan": {
      "name": "新闻获取计划",
      "description": "粘贴材料处理方式、联网补充条件和证据充分标准。",
      "type": "markdown",
      "value": "",
      "color": "#0e7490",
      "binding": null
    },
    "current_query": {
      "name": "当前搜索词",
      "description": "联网补充时交给 web_search 的查询词。",
      "type": "text",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "executed_queries": {
      "name": "联网搜索 Query",
      "description": "web_search 实际执行过的查询词。",
      "type": "json",
      "value": [],
      "color": "#7c3aed",
      "binding": {
        "kind": "action_output",
        "actionKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "query",
        "managed": true
      }
    },
    "source_urls": {
      "name": "联网搜索来源",
      "description": "web_search 成功落地原文的来源 URL。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": {
        "kind": "action_output",
        "actionKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "source_urls",
        "managed": true
      }
    },
    "artifact_paths": {
      "name": "联网原文 artifacts",
      "description": "web_search 下载到本地的网页正文文档。",
      "type": "file",
      "value": [],
      "color": "#10b981",
      "binding": {
        "kind": "action_output",
        "actionKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "artifact_paths",
        "managed": true
      }
    },
    "search_errors": {
      "name": "联网搜索错误",
      "description": "搜索或正文下载错误。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "errors",
        "managed": true
      }
    },
    "clean_news_items": {
      "name": "清洗新闻条目",
      "description": "去重后的新闻事实卡片，每条保留来源和 citation_id。",
      "type": "json",
      "value": [],
      "color": "#15803d",
      "binding": null
    },
    "citation_map": {
      "name": "新闻引用映射",
      "description": "citation_id 到链接、标题、来源和证据片段的映射。",
      "type": "json",
      "value": [],
      "color": "#db2777",
      "binding": null
    },
    "clustered_topics": {
      "name": "主题聚类",
      "description": "新闻主题聚类、重复项和合并依据。",
      "type": "json",
      "value": [],
      "color": "#0f766e",
      "binding": null
    },
    "top_news_cards": {
      "name": "Top 新闻卡片",
      "description": "按重要性排序的 Top 新闻卡片。",
      "type": "json",
      "value": [],
      "color": "#16a34a",
      "binding": null
    },
    "importance_ranking": {
      "name": "重要性排序",
      "description": "排序分数、影响维度和取舍理由。",
      "type": "json",
      "value": [],
      "color": "#65a30d",
      "binding": null
    },
    "article_outline": {
      "name": "公众号大纲",
      "description": "公众号文章结构、标题方向和段落安排。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "wechat_article": {
      "name": "公众号正文",
      "description": "带引用、可编辑的公众号正文。",
      "type": "markdown",
      "value": "",
      "color": "#ca8a04",
      "binding": null
    },
    "fact_check_report": {
      "name": "事实一致性检查",
      "description": "事实、观点、缺口、冲突和需要人工确认项。",
      "type": "json",
      "value": {},
      "color": "#dc2626",
      "binding": null
    },
    "title_candidates": {
      "name": "标题候选",
      "description": "不同角度的公众号标题候选。",
      "type": "json",
      "value": [],
      "color": "#ea580c",
      "binding": null
    },
    "distribution_pack": {
      "name": "多平台分发包",
      "description": "小红书、知乎、B站、X 等平台分发稿。",
      "type": "json",
      "value": {},
      "color": "#0891b2",
      "binding": null
    },
    "final_content_package": {
      "name": "最终内容包",
      "description": "面向用户展示和导出的完整内容包。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "session_recall_context": {
      "name": "session_recall_context",
      "description": "从 Buddy 历史会话中召回的上下文窗口。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_content_memory",
        "fieldKey": "session_recall_context",
        "managed": true
      }
    },
    "recalled_sessions": {
      "name": "recalled_sessions",
      "description": "从 Buddy 历史会话中召回的会话片段。",
      "type": "json",
      "value": [],
      "color": "#8b5cf6",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_content_memory",
        "fieldKey": "recalled_sessions",
        "managed": true
      }
    },
    "state_1": {
      "name": "Recall Request",
      "description": "会话召回请求，可包含 mode、query、session_id、anchor_message_id、direction、limit、window、bookend、sort、role_filter、current_session_id。",
      "type": "json",
      "value": {},
      "color": "#d97706"
    },
    "state_2": {
      "name": "User Question",
      "description": "用户需要联网检索、核查或补充时效信息的问题。",
      "type": "text",
      "value": "",
      "color": "#2563eb"
    }
  },
