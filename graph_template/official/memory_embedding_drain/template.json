{
  "template_id": "memory_embedding_drain",
  "label": "记忆 Embedding 入库",
  "description": "处理 Buddy 聊天消息、会话摘要和结构化记忆产生的 embedding jobs；它只消费记忆来源，不处理知识库文档。",
  "default_graph_name": "记忆 Embedding 入库",
  "state_schema": {
    "model_ref": {
      "name": "Embedding Model Ref",
      "description": "可选 embedding model id 或 provider:model；留空时使用系统默认 embedding 模型策略。",
      "type": "text",
      "value": "",
      "color": "#4f46e5",
      "binding": null
    },
    "job_limit": {
      "name": "Job Limit",
      "description": "本次最多处理的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 50,
      "color": "#0f766e",
      "binding": null
    },
    "time_budget_seconds": {
      "name": "Time Budget Seconds",
      "description": "本次 drain run 的处理时间预算秒数。",
      "type": "number",
      "value": 120,
      "color": "#d97706",
      "binding": null
    },
    "batch_size": {
      "name": "Batch Size",
      "description": "每次 provider embedding 请求中合并处理的记忆 job 数量。",
      "type": "number",
      "value": 32,
      "color": "#0891b2",
      "binding": null
    },
    "processor_status": {
      "name": "Processor Status",
      "description": "embedding_job_processor 返回的处理状态。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "status",
        "managed": true
      }
    },
    "processed_count": {
      "name": "Processed Count",
      "description": "本次检查或处理的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#7c3aed",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "processed_count",
        "managed": true
      }
    },
    "completed_count": {
      "name": "Completed Count",
      "description": "本次成功完成的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#16a34a",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "completed_count",
        "managed": true
      }
    },
    "failed_count": {
      "name": "Failed Count",
      "description": "本次失败的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#dc2626",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "failed_count",
        "managed": true
      }
    },
    "retry_wait_count": {
      "name": "Retry Wait Count",
      "description": "本次进入 retry-wait 的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#ea580c",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "retry_wait_count",
        "managed": true
      }
    },
    "blocked_count": {
      "name": "Blocked Count",
      "description": "本次被不可重试错误阻塞的记忆 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#dc2626",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "blocked_count",
        "managed": true
      }
    },
    "remaining_count": {
      "name": "Remaining Count",
      "description": "记忆来源中仍待处理的 eligible embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#0891b2",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "remaining_count",
        "managed": true
      }
    },
    "processor_report": {
      "name": "Processor Report",
      "description": "embedding_job_processor 返回的逐 job 审计记录。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "process_memory_embedding_jobs",
        "fieldKey": "processed_jobs",
        "managed": true
      }
    }
  },
  "nodes": {
    "input_model_ref": {
      "kind": "input",
      "name": "Embedding Model",
      "description": "可选模型过滤；留空时按默认模型策略处理记忆 jobs。",
      "ui": {
        "position": { "x": 80, "y": 120 },
        "collapsed": false,
        "size": { "width": 360, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "model_ref", "mode": "replace" }],
      "config": { "value": "", "boundaryType": "text" }
    },
    "input_job_limit": {
      "kind": "input",
      "name": "Job Limit",
      "description": "限制本次记忆 drain 最多处理的 jobs 数量。",
      "ui": {
        "position": { "x": 80, "y": 360 },
        "collapsed": false,
        "size": { "width": 360, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "job_limit", "mode": "replace" }],
      "config": { "value": 50, "boundaryType": "text" }
    },
    "input_time_budget_seconds": {
      "kind": "input",
      "name": "Time Budget",
      "description": "限制本次记忆 drain 的处理时间预算秒数。",
      "ui": {
        "position": { "x": 80, "y": 600 },
        "collapsed": false,
        "size": { "width": 360, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "time_budget_seconds", "mode": "replace" }],
      "config": { "value": 120, "boundaryType": "text" }
    },
    "input_batch_size": {
      "kind": "input",
      "name": "Batch Size",
      "description": "每次 embedding provider 请求合并处理的记忆 job 数量。",
      "ui": {
        "position": { "x": 80, "y": 840 },
        "collapsed": false,
        "size": { "width": 360, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "batch_size", "mode": "replace" }],
      "config": { "value": 32, "boundaryType": "text" }
    },
    "process_memory_embedding_jobs": {
      "kind": "tool",
      "name": "处理记忆 Embedding 队列",
      "description": "调用 embedding_job_processor，只处理 Buddy 消息、会话摘要和结构化记忆来源的 embedding jobs。",
      "ui": {
        "position": { "x": 620, "y": 260 },
        "collapsed": false,
        "size": { "width": 500, "height": 420 }
      },
      "reads": [
        {
          "state": "model_ref",
          "required": false,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "embedding_job_processor",
            "fieldKey": "model_ref",
            "managed": true
          }
        },
        {
          "state": "job_limit",
          "required": false,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "embedding_job_processor",
            "fieldKey": "limit",
            "managed": true
          }
        },
        {
          "state": "time_budget_seconds",
          "required": false,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "embedding_job_processor",
            "fieldKey": "time_budget_seconds",
            "managed": true
          }
        },
        {
          "state": "batch_size",
          "required": false,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "embedding_job_processor",
            "fieldKey": "batch_size",
            "managed": true
          }
        }
      ],
      "writes": [
        { "state": "processor_status", "mode": "replace" },
        { "state": "processed_count", "mode": "replace" },
        { "state": "completed_count", "mode": "replace" },
        { "state": "failed_count", "mode": "replace" },
        { "state": "retry_wait_count", "mode": "replace" },
        { "state": "blocked_count", "mode": "replace" },
        { "state": "remaining_count", "mode": "replace" },
        { "state": "processor_report", "mode": "replace" }
      ],
      "config": {
        "toolKey": "embedding_job_processor",
        "staticInputs": {
          "retry_failed": false,
          "include_retry_wait": true,
          "maintenance_only": false,
          "source_kind": "",
          "source_kinds": ["buddy_message", "buddy_session_summary", "memory_entry"],
          "collection_id": "",
          "operation_id": "",
          "source_id": ""
        }
      }
    },
    "output_processor_status": {
      "kind": "output",
      "name": "Embedding Drain Status",
      "description": "显示本次记忆 embedding drain 的处理状态。",
      "ui": {
        "position": { "x": 1260, "y": 80 },
        "collapsed": false,
        "size": { "width": 460, "height": 160 }
      },
      "reads": [{ "state": "processor_status", "required": false, "binding": null }],
      "writes": [],
      "config": { "displayMode": "plain", "persistEnabled": false, "persistFormat": "auto", "fileNameTemplate": "" }
    },
    "output_processor_report": {
      "kind": "output",
      "name": "Embedding Drain Report",
      "description": "显示本次记忆 embedding drain 的逐 job 审计记录。",
