      { "state": "processor_report", "role": "audit", "label": "Memory embedding drain audit" },
      { "state": "completed_count", "role": "metric", "label": "Completed memory embedding jobs" },
      { "state": "remaining_count", "role": "metric", "label": "Remaining memory embedding jobs" }
    ]
  }
}
