  "edges": [
    { "source": "input_model_ref", "target": "process_memory_embedding_jobs" },
    { "source": "input_job_limit", "target": "process_memory_embedding_jobs" },
    { "source": "input_time_budget_seconds", "target": "process_memory_embedding_jobs" },
    { "source": "input_batch_size", "target": "process_memory_embedding_jobs" },
    { "source": "process_memory_embedding_jobs", "target": "output_processor_status" },
    { "source": "process_memory_embedding_jobs", "target": "output_processor_report" },
    { "source": "process_memory_embedding_jobs", "target": "output_completed_count" },
    { "source": "process_memory_embedding_jobs", "target": "output_remaining_count" }
  ],
  "conditional_edges": [],
  "metadata": {
    "graphProtocol": "node_system",
    "origin": "embedding",
    "role": "memory_embedding_drain",
    "capabilityDiscoverableDefault": false,
