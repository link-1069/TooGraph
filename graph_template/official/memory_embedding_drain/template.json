        "collapsed": false,
        "size": { "width": 460, "height": 320 }
      },
      "reads": [{ "state": "processor_report", "required": true, "binding": null }],
      "writes": [],
      "config": { "displayMode": "json", "persistEnabled": false, "persistFormat": "auto", "fileNameTemplate": "" }
    },
    "output_completed_count": {
      "kind": "output",
      "name": "Completed Jobs",
      "description": "显示本次记忆 embedding jobs 的完成数量。",
      "ui": {
        "position": { "x": 1800, "y": 80 },
        "collapsed": false,
        "size": { "width": 460, "height": 160 }
      },
      "reads": [{ "state": "completed_count", "required": false, "binding": null }],
      "writes": [],
      "config": { "displayMode": "json", "persistEnabled": false, "persistFormat": "auto", "fileNameTemplate": "" }
    },
    "output_remaining_count": {
      "kind": "output",
      "name": "Remaining Jobs",
      "description": "显示记忆来源中仍待处理的 eligible embedding jobs 数量。",
      "ui": {
        "position": { "x": 1800, "y": 300 },
        "collapsed": false,
        "size": { "width": 460, "height": 160 }
      },
      "reads": [{ "state": "remaining_count", "required": false, "binding": null }],
      "writes": [],
      "config": { "displayMode": "json", "persistEnabled": false, "persistFormat": "auto", "fileNameTemplate": "" }
    }
