            "skillKey": "buddy_home_writer",
            "outputMapping": {
              "success": "writeback_success",
              "result": "writeback_result",
              "applied_commands": "applied_writeback_commands",
              "skipped_commands": "skipped_writeback_commands",
              "revisions": "writeback_revisions"
            }
          }
        ],
        "skillInstructionBlocks": {
          "buddy_home_writer": {
            "skillKey": "buddy_home_writer",
            "title": "Buddy Home Writer instruction",
            "content": "你已绑定 Buddy Home Writer。把 writeback_commands 原样作为 commands 输入，把 source_run_id 作为 run_id 输入。不要增加新命令，不要改写为通用文件写入，不要请求用户确认。技能会执行受控 command/revision 写回并返回原始结果。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只负责调用 Buddy Home Writer。commands 必须来自上游 writeback_commands；run_id 必须来自 source_run_id。不要总结、扩展、重写或伪造写回结果。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0
      }
    },
