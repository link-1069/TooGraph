    "decide_autonomous_review": {
      "kind": "agent",
      "name": "判断自主复盘",
      "description": "复盘已完成的可见 Buddy 运行，自主决定是否把稳定信息写回 Buddy Home。",
      "ui": {
        "position": {
          "x": 620,
          "y": 420
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "source_run_id",
          "required": false
        },
        {
          "state": "user_message",
          "required": true
        },
        {
          "state": "conversation_history",
          "required": false
