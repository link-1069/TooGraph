        "collapsed": false,
        "size": {
          "width": 420,
          "height": 250
        }
      },
      "reads": [
        {
          "state": "autonomous_review",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 1,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.autonomous_review.should_write",
          "operator": "==",
          "value": true
        }
      }
    },
