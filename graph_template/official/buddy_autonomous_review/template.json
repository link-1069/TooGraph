    "prepare_session_recall_request": {
      "kind": "agent",
      "name": "准备会话召回请求",
      "description": "根据本轮请求和回复生成 buddy_session_recall 的参数。",
      "ui": {
        "position": {
          "x": 620,
          "y": 260
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "source_run_id",
          "required": false
        },
        {
          "state": "current_session_id",
          "required": false
        },
        {
          "state": "user_message",
          "required": true
        },
        {
          "state": "conversation_history",
          "required": false
        },
        {
          "state": "request_understanding",
          "required": true
        },
        {
          "state": "public_response",
          "required": true
        }
      ],
      "writes": [
        {
          "state": "recall_request",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "生成一个 recall_request JSON，只用于 buddy_session_recall 读取 buddy.db。优先使用 mode=discover、sort=newest、limit<=6、window<=2、bookend<=2、role_filter=[\"user\",\"assistant\"]。query 应来自本轮用户目标、稳定偏好、关键项目名、记忆落盘相关词或最终回复中的长期事实，不要包含敏感全文或临时日志。把 current_session_id 原样放入 recall_request.current_session_id；如果没有可检索关键词，可使用 mode=browse。不要总结召回结果，不写 MEMORY.md。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.1
      }
    },
    "recall_related_sessions": {
      "kind": "agent",
      "name": "召回相关历史会话",
      "description": "运行 buddy_session_recall，只透传 buddy.db 中的会话窗口。",
      "ui": {
        "position": {
          "x": 1160,
          "y": 260
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
      },
      "reads": [
        {
          "state": "recall_request",
          "required": true,
          "binding": {
            "kind": "action_input",
            "actionKey": "buddy_session_recall",
            "fieldKey": "recall_request",
            "managed": true
          }
        }
      ],
      "writes": [
        {
          "state": "buddy_session_recall_success",
          "mode": "replace"
        },
        {
          "state": "session_recall_context",
          "mode": "replace"
        },
        {
          "state": "recalled_sessions",
          "mode": "replace"
        },
        {
          "state": "buddy_session_recall_result",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "buddy_session_recall",
        "actionBindings": [
          {
            "actionKey": "buddy_session_recall",
            "outputMapping": {
              "success": "buddy_session_recall_success",
              "session_recall_context": "session_recall_context",
              "sessions": "recalled_sessions",
              "result": "buddy_session_recall_result"
            }
          }
        ],
        "actionInstructionBlocks": {
          "buddy_session_recall": {
            "actionKey": "buddy_session_recall",
            "title": "Buddy session recall instruction",
            "content": "你已绑定 Buddy 会话召回 Action。只把 recall_request 转为会话召回参数；使用 browse、discover 或 scroll，不要使用旧 memories 表字段。必须保留 current_session_id 以排除当前会话谱系。不要总结、不要写入 MEMORY.md。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只负责运行 buddy_session_recall。输入来自 recall_request；输出写入 session_recall_context、recalled_sessions 和 buddy_session_recall_result。不要输出记忆结论，不创建写回命令。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0
      }
    },
