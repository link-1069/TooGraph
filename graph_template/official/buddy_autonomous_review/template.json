      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "recall_request": {
      "name": "recall_request",
      "description": "传给 buddy_session_recall 的只读会话召回参数。",
      "type": "json",
      "value": {
        "mode": "discover",
        "query": "",
        "limit": 6,
        "window": 2,
        "bookend": 2,
        "sort": "newest"
