{
  "template_id": "buddy_autonomous_review",
  "label": "自主复盘",
  "description": "可见 Buddy 回复完成后的后台复盘模板：先召回相关会话，再提取、过滤、合并长期记忆候选，必要时通过 Buddy Home Writer 写入 MEMORY.md。",
  "default_graph_name": "自主复盘",
  "state_schema": {
    "source_run_id": {
      "name": "source_run_id",
      "description": "触发本次自主复盘的可见 Buddy run ID。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "user_message": {
      "name": "user_message",
      "description": "用户本轮对伙伴说的话。",
      "type": "text",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "conversation_history": {
      "name": "conversation_history",
      "description": "伙伴对话历史摘要。",
      "type": "markdown",
      "value": "",
      "color": "#64748b",
      "binding": null
    },
    "page_context": {
      "name": "page_context",
      "description": "当前页面、选中图、节点或其他 UI 上下文。",
      "type": "markdown",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "buddy_context": {
      "name": "buddy_context",
      "description": "从 Buddy Home 文件夹中选择并注入的长期上下文文件。",
      "type": "file",
      "value": {
        "kind": "local_folder",
        "root": "buddy_home",
        "selected": [
          "AGENTS.md",
          "SOUL.md",
          "USER.md",
          "MEMORY.md",
          "policy.json"
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "request_understanding": {
      "name": "request_understanding",
      "description": "对用户请求的结构化理解、澄清需求、目标和约束。",
      "type": "json",
      "value": {},
      "color": "#16a34a",
      "binding": null
    },
    "capability_result": {
      "name": "capability_result",
      "description": "动态能力执行后的结果包。包内每个输出保留原始 name、description、type 和 value。",
      "type": "result_package",
      "value": {},
      "color": "#0284c7",
      "binding": null
    },
    "capability_review": {
      "name": "capability_review",
      "description": "对能力选择、权限、执行结果和是否继续调用能力的复盘。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "public_response": {
      "name": "public_response",
      "description": "展示给用户的最终伙伴回复。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    },
    "current_session_id": {
      "name": "current_session_id",
      "description": "当前 Buddy 会话 ID；用于会话召回时排除同一 parent lineage，避免重复召回本轮上下文。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "recall_request": {
      "name": "recall_request",
      "description": "传给 buddy_session_recall 的只读会话召回参数。",
      "type": "json",
      "value": {
        "mode": "discover",
        "query": "",
        "limit": 6,
        "window": 2,
        "bookend": 2,
        "sort": "newest"
      },
      "color": "#4f46e5",
      "binding": null
    },
    "buddy_session_recall_success": {
      "name": "buddy_session_recall_success",
      "description": "buddy_session_recall Action 是否成功执行。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_related_sessions",
        "fieldKey": "success",
        "managed": true
      }
    },
    "session_recall_context": {
      "name": "session_recall_context",
      "description": "从 buddy.db 召回的 Hermes 风格会话窗口、snippet、bookends 和 lineage 信息。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_related_sessions",
        "fieldKey": "session_recall_context",
        "managed": true
      }
    },
    "recalled_sessions": {
      "name": "recalled_sessions",
      "description": "buddy_session_recall 返回的会话片段列表。",
      "type": "json",
      "value": [],
      "color": "#6d28d9",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_related_sessions",
        "fieldKey": "sessions",
        "managed": true
      }
    },
    "buddy_session_recall_result": {
      "name": "buddy_session_recall_result",
      "description": "buddy_session_recall 返回的召回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#5b21b6",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_related_sessions",
        "fieldKey": "result",
        "managed": true
      }
    },
    "autonomous_review": {
      "name": "autonomous_review",
      "description": "本轮自主复盘结论，包含候选数量、理由、证据、风险标记和跳过原因。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "improvement_candidates": {
      "name": "improvement_candidates",
      "description": "后台复盘产出的可审查改进候选；不会直接应用高风险或持久变更。",
      "type": "json",
      "value": [],
      "color": "#7c3aed",
      "binding": null
    },
    "memory_candidates": {
      "name": "memory_candidates",
      "description": "从本轮运行、Buddy Home 和召回会话中提取的长期记忆候选。",
      "type": "json",
      "value": [],
      "color": "#0f766e",
      "binding": null
    },
    "memory_filter_report": {
      "name": "memory_filter_report",
      "description": "候选记忆的去重、风险、证据、长期价值和写入资格过滤报告。",
      "type": "json",
      "value": {
        "accepted": [],
        "rejected": []
      },
      "color": "#0e7490",
      "binding": null
    },
    "memory_update_plan": {
      "name": "memory_update_plan",
      "description": "交给 Buddy Home Writer 的 MEMORY.md 更新计划；包含是否更新、完整新文档和命令数组。",
      "type": "json",
      "value": {
        "has_updates": false,
        "commands": []
      },
      "color": "#22c55e",
      "binding": null
    },
    "memory_review_result": {
      "name": "memory_review_result",
      "description": "后台记忆整理结果摘要；说明写入、跳过和证据来源。",
      "type": "markdown",
      "value": "",
      "color": "#0369a1",
      "binding": null
    },
    "memory_write_success": {
      "name": "memory_write_success",
      "description": "Buddy Home Writer 是否成功应用全部 MEMORY.md 更新命令。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "success",
        "managed": true
      }
    },
    "applied_memory_commands": {
      "name": "applied_memory_commands",
      "description": "已应用的 Buddy Home 写回命令和 revision 信息。",
      "type": "json",
      "value": [],
      "color": "#059669",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "applied_commands",
        "managed": true
      }
    },
    "skipped_memory_commands": {
      "name": "skipped_memory_commands",
      "description": "因内容无效、风险过高或写入失败而跳过的 Buddy Home 写回命令。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "skipped_commands",
        "managed": true
      }
    },
    "memory_write_result": {
      "name": "memory_write_result",
      "description": "Buddy Home 写回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#15803d",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "result",
        "managed": true
      }
    },
    "state_1": {
      "name": "Autonomous Review",
      "description": "Buddy 自主复盘或写回计划 state，供 LLM 生成低风险 Buddy Home 写回 commands。",
      "type": "json",
      "value": {},
      "color": "#d97706"
    }
