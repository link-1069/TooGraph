        {
          "state": "memory_update_plan",
          "required": true
        }
      ],
      "writes": [
        {
          "state": "memory_write_success",
          "mode": "replace"
        },
        {
          "state": "applied_memory_commands",
          "mode": "replace"
        },
        {
          "state": "skipped_memory_commands",
          "mode": "replace"
        },
        {
          "state": "memory_write_result",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "buddy_home_writer",
        "actionBindings": [
          {
            "actionKey": "buddy_home_writer",
            "outputMapping": {
              "success": "memory_write_success",
              "applied_commands": "applied_memory_commands",
              "skipped_commands": "skipped_memory_commands",
              "result": "memory_write_result"
            }
          }
        ],
        "actionInstructionBlocks": {
          "buddy_home_writer": {
            "actionKey": "buddy_home_writer",
            "title": "MEMORY.md writeback instruction",
            "content": "你已绑定 Buddy Home Writer。只把 memory_update_plan.commands 原样作为 commands 输入；每条命令必须是 memory_document.update，并写入完整 MEMORY.md 内容。把 source_run_id 作为 run_id；不要新增命令、不要改写命令语义、不要触碰 MEMORY.md 以外的文件或策略。",
            "source": "node.override"
