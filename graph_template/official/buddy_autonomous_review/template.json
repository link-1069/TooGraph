    "autonomous_review": {
      "name": "autonomous_review",
      "description": "本轮自主复盘结论，包含候选数量、理由、证据、风险标记和跳过原因。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "improvement_candidates": {
      "name": "improvement_candidates",
