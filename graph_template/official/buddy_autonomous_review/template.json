        {
          "state": "recalled_sessions",
          "mode": "replace"
        },
        {
          "state": "buddy_session_recall_result",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "buddy_session_recall",
        "actionBindings": [
          {
            "actionKey": "buddy_session_recall",
            "outputMapping": {
              "success": "buddy_session_recall_success",
              "session_recall_context": "session_recall_context",
              "sessions": "recalled_sessions",
              "result": "buddy_session_recall_result"
            }
          }
        ],
        "actionInstructionBlocks": {
          "buddy_session_recall": {
            "actionKey": "buddy_session_recall",
            "title": "Buddy session recall instruction",
            "content": "你已绑定 Buddy 会话召回 Action。只把 recall_request 转为会话召回参数；使用 browse、discover 或 scroll，不要使用旧 memories 表字段。必须保留 current_session_id 以排除当前会话谱系。不要总结、不要写入 MEMORY.md。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只负责运行 buddy_session_recall。输入来自 recall_request；输出写入 session_recall_context、recalled_sessions 和 buddy_session_recall_result。不要输出记忆结论，不创建写回命令。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0
      }
    },
