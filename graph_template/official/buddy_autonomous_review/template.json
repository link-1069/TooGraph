{
  "template_id": "buddy_autonomous_review",
  "label": "自主复盘",
  "description": "可见 Buddy 回复完成后的后台复盘模板：召回相关会话，产出记忆、profile 和改进候选，并在同一图内通过 Buddy Home Writer 写入低风险记忆更新。",
  "default_graph_name": "自主复盘",
  "state_schema": {
    "source_run_id": {
      "name": "source_run_id",
      "description": "触发本次自主复盘的可见 Buddy run ID。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "current_session_id": {
      "name": "current_session_id",
      "description": "当前 Buddy 会话 ID；用于会话召回时排除同一 parent lineage，避免重复召回本轮上下文。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "user_message": {
      "name": "user_message",
      "description": "用户本轮对伙伴说的话。",
      "type": "text",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "conversation_history": {
      "name": "conversation_history",
      "description": "伙伴对话历史摘要。",
      "type": "markdown",
      "value": "",
      "color": "#64748b",
      "binding": null
    },
    "buddy_context": {
      "name": "buddy_context",
      "description": "从 Buddy Home 文件夹中选择并注入的长期上下文文件。",
      "type": "file",
      "value": {
        "kind": "local_folder",
        "root": "buddy_home",
        "selected": [
          "AGENTS.md",
          "SOUL.md",
          "USER.md",
          "MEMORY.md"
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "request_understanding": {
      "name": "request_understanding",
      "description": "对用户请求的结构化理解、澄清需求、目标和约束。",
      "type": "json",
      "value": {},
      "color": "#16a34a",
      "binding": null
    },
    "capability_result": {
      "name": "capability_result",
      "description": "动态能力执行后的结果包。包内每个输出保留原始 name、description、type 和 value。",
      "type": "result_package",
      "value": {},
      "color": "#0284c7",
      "binding": null
    },
    "capability_review": {
      "name": "capability_review",
      "description": "对能力选择、权限、执行结果和是否继续调用能力的复盘。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "public_response": {
      "name": "public_response",
      "description": "展示给用户的最终伙伴回复。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    },
    "session_recall_context": {
      "name": "session_recall_context",
      "description": "从 buddy.db 召回的相关会话窗口、snippet、bookends 和 lineage 信息；仅作为复盘上下文。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_related_sessions",
        "fieldKey": "session_recall_context",
        "managed": true
      }
    },
    "autonomous_review": {
      "name": "autonomous_review",
      "description": "本轮自主复盘结论，包含候选数量、证据、风险、跳过原因和后续建议。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "improvement_candidates": {
      "name": "improvement_candidates",
      "description": "可审查的 Action、模板、工作流或策略改进候选；后台复盘不直接应用。",
      "type": "json",
      "value": [],
      "color": "#7c3aed",
      "binding": null
    },
    "memory_update_plan": {
      "name": "memory_update_plan",
      "description": "MEMORY.md 更新计划；复盘节点只生成低风险 writer-ready commands，下游 Buddy Home Writer 在同一模板内写入并留下 revision。",
      "type": "json",
      "value": {
        "has_updates": false,
        "commands": []
      },
      "color": "#22c55e",
      "binding": null
    },
    "memory_review_result": {
      "name": "memory_review_result",
      "description": "后台记忆复盘摘要；说明接受、拒绝、去重、风险和待人工确认项。",
      "type": "markdown",
      "value": "",
      "color": "#0369a1",
      "binding": null
    },
    "profile_update_plan": {
      "name": "profile_update_plan",
      "description": "Buddy profile/SOUL.md 更新计划；只有明确低风险 profile.update commands 才会被下游 Writer 写入。",
      "type": "json",
      "value": {
        "has_updates": false,
        "requires_confirmation": false,
        "commands": []
      },
      "color": "#f97316",
      "binding": null
    },
    "profile_review_result": {
      "name": "profile_review_result",
      "description": "Profile/self-configuration 复盘摘要；说明接受、拒绝和需要确认的候选。",
      "type": "markdown",
      "value": "",
      "color": "#c2410c",
      "binding": null
    },
    "memory_write_success": {
      "name": "memory_write_success",
      "description": "Buddy Home Writer 是否成功应用全部 MEMORY.md 更新命令。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "success",
        "managed": true
      }
    },
    "applied_memory_commands": {
      "name": "applied_memory_commands",
      "description": "已应用的 MEMORY.md 写回命令和 revision 信息。",
      "type": "json",
      "value": [],
      "color": "#059669",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "applied_commands",
        "managed": true
      }
    },
    "skipped_memory_commands": {
      "name": "skipped_memory_commands",
      "description": "因内容无效、风险过高或写入失败而跳过的 MEMORY.md 写回命令。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "skipped_commands",
        "managed": true
      }
    },
    "memory_write_result": {
      "name": "memory_write_result",
      "description": "MEMORY.md 写回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#15803d",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_memory_updates",
        "fieldKey": "result",
        "managed": true
      }
    },
    "profile_write_success": {
      "name": "profile_write_success",
      "description": "Buddy Home Writer 是否成功应用全部 profile.update 命令。",
      "type": "boolean",
      "value": false,
      "color": "#ea580c",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_profile_updates",
        "fieldKey": "success",
        "managed": true
      }
    },
    "applied_profile_commands": {
      "name": "applied_profile_commands",
      "description": "已应用的 profile.update 命令和 revision 信息。",
      "type": "json",
      "value": [],
      "color": "#f97316",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_profile_updates",
        "fieldKey": "applied_commands",
        "managed": true
      }
    },
    "skipped_profile_commands": {
      "name": "skipped_profile_commands",
      "description": "因意图不明确、风险过高或写入失败而跳过的 profile.update 命令。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_profile_updates",
        "fieldKey": "skipped_commands",
        "managed": true
      }
    },
    "profile_write_result": {
      "name": "profile_write_result",
      "description": "Buddy profile 写回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#ea580c",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_profile_updates",
        "fieldKey": "result",
        "managed": true
      }
    }
