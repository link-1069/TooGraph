    "test_plan": {
      "name": "测试计划",
      "description": "候选应用前需要运行的验证命令、validation case 或人工检查步骤。",
      "type": "markdown",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "approval_request": {
      "name": "审批请求",
      "description": "面向用户或 reviewer 的结构化审批请求，包含风险、diff 摘要、验证结果和可批准操作。",
      "type": "json",
      "value": {},
      "color": "#b45309",
      "binding": null
