      "name": "校验成功",
      "description": "图模板校验器是否通过协议、图校验和运行时兼容检查。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_graph_template_validator",
        "nodeId": "validate_candidate_template",
        "fieldKey": "success",
        "managed": true
