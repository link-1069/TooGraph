    "validation_report": {
      "name": "校验报告",
      "description": "协议、图校验、运行时兼容和问题列表。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_graph_template_validator",
        "nodeId": "validate_candidate_template",
        "fieldKey": "validation_report",
        "managed": true
      }
