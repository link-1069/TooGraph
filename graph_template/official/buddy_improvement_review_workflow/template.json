{
  "template_id": "buddy_improvement_review_workflow",
  "label": "改进候选验证",
  "description": "将自主复盘产出的 improvement candidate 转成可审查的验证报告、diff proposal、测试计划和 approval request；本模板只验证和请求审批，不应用改动。",
  "default_graph_name": "改进候选验证",
  "state_schema": {
    "improvement_candidate": {
      "name": "改进候选",
      "description": "来自后台复盘或 curator 的 improvement_candidate 对象，包含 candidate_id、kind、target_ref、evidence_refs、risk_level 和 proposed_change_summary。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "source_run_id": {
      "name": "来源 Run ID",
      "description": "产生该候选的源 run ID，用于追溯证据和审批说明。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "candidate_review_context": {
      "name": "候选审查上下文",
      "description": "从 improvement_candidate 规范化得到的候选类型、目标引用、风险、证据和验证方向。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "target_action_key": {
      "name": "目标 Action Key",
      "description": "候选指向的 Action key；为空表示本轮无需读取 Action 包。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": null
    },
    "target_template_id": {
      "name": "目标模板 ID",
      "description": "候选指向的图模板 ID；为空表示本轮无需读取图模板包。",
      "type": "text",
      "value": "",
      "color": "#9333ea",
      "binding": null
    },
    "action_read_success": {
      "name": "Action 读取成功",
      "description": "Action Package Reader 是否读取到目标 Action 包。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_action_package_reader",
        "nodeId": "read_target_action",
        "fieldKey": "success",
        "managed": true
      }
    },
    "action_package": {
      "name": "Action 包",
      "description": "读取到的 Action manifest、文档和脚本内容。",
      "type": "json",
      "value": {},
      "color": "#2563eb",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_action_package_reader",
        "nodeId": "read_target_action",
        "fieldKey": "action_package",
        "managed": true
      }
    },
    "action_read_result": {
      "name": "Action 读取摘要",
      "description": "Action 包读取结果摘要或错误原因。",
      "type": "markdown",
      "value": "",
      "color": "#15803d",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_action_package_reader",
        "nodeId": "read_target_action",
        "fieldKey": "result",
        "managed": true
      }
    },
    "template_read_success": {
      "name": "模板读取成功",
      "description": "图模板读取器是否读取到目标模板。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "toograph_graph_template_reader",
        "nodeId": "read_target_template",
        "fieldKey": "success",
        "managed": true
