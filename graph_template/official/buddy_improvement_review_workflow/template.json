    "candidate_status_recommendation": {
      "name": "候选状态建议",
      "description": "本轮验证后建议将候选标记为 validated、needs_changes、rejected 或 waiting_for_approval。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
