      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "proposed_diff": {
      "name": "候选 Diff Proposal",
      "description": "面向 review 的结构化 diff proposal；包含目标、变更摘要、文件或模板路径、风险和回滚说明。",
