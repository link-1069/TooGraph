{
  "template_id": "toograph_skill_creation_workflow",
  "label": "创建自定义 Skill",
  "description": "需求澄清、样例确认、Skill 文件生成、脚本测试修复、生成方案审查和运行时权限控制写入的自定义 Skill 创作图模板。",
  "default_graph_name": "创建自定义 Skill",
  "state_schema": {
    "skill_request": {
      "name": "用户需求",
      "description": "用户想创建的 Skill 能力、输入输出期望和限制。",
      "type": "text",
      "value": "我想要一个把会议纪要整理成待办清单的 Skill",
      "color": "#d97706",
      "binding": null
    },
    "capability_gap": {
      "name": "capability_gap",
      "description": "可选的能力缺口上下文，通常来自 Buddy 主循环在找不到合适能力时生成的结构化 gap。",
      "type": "json",
      "value": {},
      "color": "#dc2626",
      "binding": null
    },
    "existing_capability": {
      "name": "已有能力",
      "description": "能力选择技能从当前启用模板和 Skill 中选择出的单个可用能力候选；这里作为审查上下文保存，不触发动态执行。",
      "type": "json",
      "value": {
        "kind": "none"
      },
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_capability_selector",
        "nodeId": "select_existing_capability",
        "fieldKey": "capability",
        "managed": true
      }
    },
    "existing_capability_found": {
      "name": "已有能力可用",
      "description": "能力选择技能是否找到了可复用的启用模板或 Skill；下游节点只用这个布尔值做分支判断。",
      "type": "boolean",
      "value": false,
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_capability_selector",
        "nodeId": "select_existing_capability",
        "fieldKey": "found",
        "managed": true
      }
    },
    "requirement_review": {
      "name": "需求评估",
      "description": "对需求是否清晰、是否已有能力可复用、是否继续创建 Skill 的结构化判断。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "creation_decision": {
      "name": "创建决策",
      "description": "是否继续创建新 Skill 的结构化决策。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "clarification_questions": {
      "name": "澄清问题",
      "description": "当需求不够清晰时，面向用户提出的问题和选项。",
      "type": "markdown",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "clarification_answer": {
      "name": "用户澄清回答",
      "description": "用户对澄清问题的回答，可以选择选项，也可以自由补充。",
      "type": "markdown",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "confirmed_skill_requirement": {
      "name": "确认后的需求",
      "description": "经过澄清后确认的 Skill 需求、边界、输入输出和约束。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    },
    "example_io": {
      "name": "示例输入输出",
      "description": "用于给用户确认的示例输入、预期输出和边界示例。",
      "type": "markdown",
      "value": "",
      "color": "#7c3aed",
      "binding": null
    },
    "example_feedback": {
      "name": "样例反馈",
      "description": "用户对示例输入输出的认可或修改意见。",
      "type": "markdown",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "example_decision": {
      "name": "样例决策",
      "description": "样例是否获得用户认可，以及需要修改的点。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "builder_context": {
      "name": "构建上下文",
      "description": "交给 Skill Builder 的最终需求、示例、文件约束和修复上下文。",
      "type": "markdown",
      "value": "",
      "color": "#4f46e5",
      "binding": null
    },
    "generated_skill_key": {
      "name": "Skill Key",
      "description": "生成的 Skill 稳定机器标识。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "skill_key",
        "managed": true
      }
    },
    "generated_skill_json": {
      "name": "skill.json",
      "description": "生成的 Skill manifest JSON 对象。",
      "type": "json",
      "value": {},
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "skill_json",
        "managed": true
      }
    },
    "generated_skill_md": {
      "name": "SKILL.md",
      "description": "生成的 Skill 使用说明 Markdown。",
      "type": "markdown",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "skill_md",
        "managed": true
      }
    },
    "generated_before_llm_py": {
      "name": "before_llm.py",
      "description": "生成的 before_llm.py 源码；不需要时为空字符串。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "before_llm_py",
        "managed": true
      }
    },
    "generated_after_llm_py": {
      "name": "after_llm.py",
      "description": "生成的 after_llm.py 源码；不需要时为空字符串。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "after_llm_py",
        "managed": true
      }
    },
    "generated_requirements_txt": {
      "name": "requirements.txt",
      "description": "生成的 requirements.txt 内容；不需要第三方依赖时为空字符串。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_skill_builder",
        "nodeId": "build_skill_files",
        "fieldKey": "requirements_txt",
        "managed": true
      }
    },
    "test_strategy": {
      "name": "测试策略",
      "description": "是否需要测试 Python 生命周期脚本，以及测试哪个脚本。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "script_test_success": {
      "name": "脚本测试是否成功",
      "description": "脚本测试命令是否成功退出。",
      "type": "boolean",
      "value": false,
      "color": "#9333ea",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_script_tester",
        "nodeId": "run_script_test",
        "fieldKey": "success",
        "managed": true
      }
    },
    "script_test_result": {
      "name": "脚本测试结果",
      "description": "脚本测试输出或报错信息。",
      "type": "markdown",
      "value": "",
      "color": "#9333ea",
      "binding": {
        "kind": "skill_output",
        "skillKey": "toograph_script_tester",
        "nodeId": "run_script_test",
        "fieldKey": "result",
        "managed": true
      }
    },
    "generation_review": {
      "name": "生成结果审查",
      "description": "写入前给用户审查的 Skill 文件摘要、测试结果和目标路径。",
      "type": "markdown",
      "value": "",
      "color": "#0f766e",
      "binding": null
    },
    "final_summary": {
      "name": "最终回复",
      "description": "面向用户展示的最终结果、文件路径、测试状态和后续建议。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "write_skill_json_success": {
      "name": "skill.json 写入成功",
      "description": "skill.json 写入操作是否成功。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "skill_output",
