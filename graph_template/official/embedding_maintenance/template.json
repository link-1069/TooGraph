{
  "template_id": "embedding_maintenance",
  "label": "Embedding 队列维护",
  "description": "定期维护 embedding 队列：恢复过期运行、重置可重试失败、同步知识库入库状态，并唤醒可继续处理的记忆或知识库入库图；本图不直接生成向量。",
  "default_graph_name": "Embedding 队列维护",
  "state_schema": {
    "model_ref": {
      "name": "Embedding Model Ref",
      "description": "可选 embedding model id 或 provider:model；留空时维护所有模型的队列。",
      "type": "text",
      "value": "",
      "color": "#2563eb",
      "binding": null
    },
    "processor_status": {
      "name": "Processor Status",
      "description": "embedding_job_processor 返回的维护状态。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "status",
        "managed": true
      }
    },
    "reset_stale_running_count": {
      "name": "Reset Stale Running Count",
      "description": "本次维护恢复的过期 running jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#d97706",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "reset_stale_running_count",
        "managed": true
      }
    },
    "retried_failed_count": {
      "name": "Retried Failed Count",
      "description": "本次维护重置为 pending 的 failed jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#dc2626",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "retried_failed_count",
        "managed": true
      }
    },
    "ready_memory_job_count": {
      "name": "Ready Memory Job Count",
      "description": "当前可由记忆 embedding drain 处理的 jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#7c3aed",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "ready_memory_job_count",
        "managed": true
      }
    },
    "ready_knowledge_operation_count": {
      "name": "Ready Knowledge Operation Count",
      "description": "当前可继续处理的知识库入库 operation 数量。",
      "type": "number",
      "value": 0,
      "color": "#0f766e",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "ready_knowledge_operation_count",
        "managed": true
      }
    },
    "synced_operation_count": {
      "name": "Synced Operation Count",
      "description": "本次维护同步过状态的知识库入库 operation 数量。",
      "type": "number",
      "value": 0,
      "color": "#0891b2",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "synced_operation_count",
        "managed": true
      }
    },
    "remaining_count": {
      "name": "Remaining Count",
      "description": "维护范围内仍可处理的 embedding jobs 数量。",
      "type": "number",
      "value": 0,
      "color": "#9333ea",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "remaining_count",
        "managed": true
      }
    },
    "maintenance_report": {
      "name": "Maintenance Report",
      "description": "本次队列维护与知识库 operation 同步报告。",
      "type": "json",
      "value": {},
      "color": "#64748b",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "embedding_job_processor",
        "nodeId": "maintain_embedding_queue",
        "fieldKey": "maintenance_report",
        "managed": true
      }
    }
  },
  "nodes": {
    "input_model_ref": {
      "kind": "input",
      "name": "Embedding Model",
      "description": "可选模型过滤；通常保持为空，由各 drain 图按默认模型策略处理。",
      "ui": {
        "position": { "x": 80, "y": 120 },
        "collapsed": false,
        "size": { "width": 360, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "model_ref", "mode": "replace" }],
      "config": {
        "value": "",
        "boundaryType": "text"
      }
    },
    "maintain_embedding_queue": {
      "kind": "tool",
      "name": "维护 Embedding 队列",
      "description": "调用 embedding_job_processor 的 maintenance-only 模式，只做队列恢复、失败重试准备和状态同步。",
      "ui": {
        "position": { "x": 620, "y": 160 },
        "collapsed": false,
        "size": { "width": 500, "height": 360 }
      },
      "reads": [
        {
          "state": "model_ref",
          "required": false,
          "binding": {
            "kind": "tool_input",
            "actionKey": "",
            "toolKey": "embedding_job_processor",
            "fieldKey": "model_ref",
            "managed": true
          }
        }
      ],
      "writes": [
        { "state": "processor_status", "mode": "replace" },
        { "state": "reset_stale_running_count", "mode": "replace" },
        { "state": "retried_failed_count", "mode": "replace" },
        { "state": "ready_memory_job_count", "mode": "replace" },
        { "state": "ready_knowledge_operation_count", "mode": "replace" },
        { "state": "synced_operation_count", "mode": "replace" },
        { "state": "remaining_count", "mode": "replace" },
        { "state": "maintenance_report", "mode": "replace" }
      ],
      "config": {
        "toolKey": "embedding_job_processor",
        "staticInputs": {
          "maintenance_only": true,
          "retry_failed": true,
          "include_retry_wait": true,
          "limit": 500,
          "batch_size": 1,
          "collection_id": "",
          "operation_id": "",
          "source_kind": "",
          "source_kinds": [],
          "source_id": "",
          "time_budget_seconds": 0
        }
      }
    },
    "output_queue_status": {
      "kind": "output",
      "name": "维护状态",
      "description": "显示队列维护状态。",
      "ui": {
        "position": { "x": 1240, "y": 80 },
        "collapsed": false,
        "size": { "width": 420, "height": 160 }
      },
      "reads": [{ "state": "processor_status", "required": false, "binding": null }],
      "writes": [],
      "config": {
        "displayMode": "plain",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_ready_memory": {
      "kind": "output",
      "name": "可处理记忆任务",
      "description": "显示可由记忆 drain 消费的 jobs 数量。",
      "ui": {
        "position": { "x": 1240, "y": 300 },
        "collapsed": false,
        "size": { "width": 420, "height": 160 }
      },
      "reads": [{ "state": "ready_memory_job_count", "required": false, "binding": null }],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_ready_knowledge": {
      "kind": "output",
      "name": "可继续知识库任务",
      "description": "显示可继续处理的知识库 operation 数量。",
      "ui": {
        "position": { "x": 1240, "y": 520 },
        "collapsed": false,
        "size": { "width": 420, "height": 160 }
      },
      "reads": [{ "state": "ready_knowledge_operation_count", "required": false, "binding": null }],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_maintenance_report": {
      "kind": "output",
      "name": "维护报告",
      "description": "显示本次维护的结构化报告。",
      "ui": {
        "position": { "x": 1740, "y": 160 },
        "collapsed": false,
        "size": { "width": 460, "height": 320 }
      },
      "reads": [{ "state": "maintenance_report", "required": false, "binding": null }],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    { "source": "input_model_ref", "target": "maintain_embedding_queue" },
    { "source": "maintain_embedding_queue", "target": "output_queue_status" },
    { "source": "maintain_embedding_queue", "target": "output_ready_memory" },
    { "source": "maintain_embedding_queue", "target": "output_ready_knowledge" },
    { "source": "maintain_embedding_queue", "target": "output_maintenance_report" }
  ],
  "conditional_edges": [],
  "metadata": {
    "graphProtocol": "node_system",
    "origin": "embedding",
    "role": "embedding_queue_maintenance",
    "capabilityDiscoverableDefault": false,
    "requiredTools": ["embedding_job_processor"],
    "outputContract": [
      { "state": "processor_status", "role": "status", "label": "Embedding queue maintenance status" },
      { "state": "ready_memory_job_count", "role": "metric", "label": "Ready memory embedding jobs" },
      { "state": "ready_knowledge_operation_count", "role": "metric", "label": "Ready knowledge embedding operations" },
      { "state": "maintenance_report", "role": "audit", "label": "Embedding queue maintenance report" }
    ]
  }
}
