          "state": "writer_input",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "执行 Hermes 风格上下文压缩。基于 existing_session_summary 迭代更新，不要从零抹掉已有摘要；保护最近原文，写入 protected_recent_history Markdown；把中间历史、用户明确决策、当前任务进展、未完成事项、能力调用结论压成 session_summary_candidate Markdown。不要保存原始日志、完整错误、敏感信息、临时路径、base64 或可从当前图重读的巨大内容。必须同时输出：compaction_report JSON（trigger、source_run_id、current_session_id、omitted_count、protected_count、summary_changed、risk_notes、anti_thrashing_notes）、should_write_summary boolean、writer_input JSON。writer_input.commands 只允许一个 session_summary.update 命令，payload.content 必须等于 session_summary_candidate；change_reason 写明触发来源和压缩理由。若摘要无实质变化或风险过高，should_write_summary=false 且 commands=[]。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.1
      }
    },
    "has_summary_update": {
      "kind": "condition",
      "name": "需要写入摘要?",
      "description": "只有摘要发生实质更新时才调用 Buddy Home Writer。",
      "ui": {
        "position": {
          "x": 1880,
          "y": 1260
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 250
        }
