            "actionKey": "buddy_home_writer",
            "outputMapping": {
              "success": "session_summary_write_success",
              "applied_commands": "applied_session_summary_commands",
              "skipped_commands": "skipped_session_summary_commands",
              "result": "session_summary_write_result"
            }
          }
        ],
        "actionInstructionBlocks": {
          "buddy_home_writer": {
            "actionKey": "buddy_home_writer",
            "title": "session_summary writeback instruction",
            "content": "你已绑定 Buddy Home Writer。只把 writer_input.commands 原样作为 commands 输入；每条命令必须是 session_summary.update，payload.content 必须是完整的新会话摘要。run_id 使用 source_run_id；不要新增命令、不要写 MEMORY.md、不要修改 profile/policy。",
            "source": "node.override"
          }
        },
        "taskInstruction": "本节点只负责调用 buddy_home_writer。commands 必须来自 writer_input.commands；run_id 必须来自 source_run_id。不要总结、扩展、重写或伪造写回结果。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0
      }
    },
