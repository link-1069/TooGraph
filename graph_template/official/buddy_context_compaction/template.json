      "reads": [
        {
          "state": "should_write_summary",
          "required": true
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 1,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.should_write_summary",
          "operator": "==",
          "value": true
        }
      }
    },
