{
  "template_id": "buddy_context_compaction",
  "label": "上下文压缩",
  "description": "Hermes 风格 Buddy 上下文压缩模板：保护最近原文，把中间历史压成会话摘要，并通过 Buddy Home Writer 更新 session_summary。",
  "default_graph_name": "上下文压缩",
  "state_schema": {
    "trigger": {
      "name": "trigger",
      "description": "触发压缩的来源：preflight、capability_result、overflow_recovery 或 background。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "source_run_id": {
      "name": "source_run_id",
      "description": "触发本次压缩的可见 Buddy run ID；preflight 可能为空。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "current_session_id": {
      "name": "current_session_id",
      "description": "当前 Buddy 会话 ID，用于标记摘要来源。",
      "type": "text",
      "value": "",
      "color": "#475569",
      "binding": null
    },
    "user_message": {
      "name": "user_message",
      "description": "本轮用户消息。",
      "type": "text",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "conversation_history": {
      "name": "conversation_history",
      "description": "压缩前可见的完整或尽量完整的会话历史原文。",
      "type": "markdown",
      "value": "",
      "color": "#64748b",
      "binding": null
    },
    "existing_session_summary": {
      "name": "existing_session_summary",
      "description": "已有会话摘要；压缩时应迭代更新而不是从零替换。",
      "type": "markdown",
      "value": "",
      "color": "#4f46e5",
      "binding": null
    },
    "buddy_context": {
      "name": "buddy_context",
      "description": "从 Buddy Home 文件夹注入的长期上下文文件。",
      "type": "file",
      "value": {
        "kind": "local_folder",
        "root": "buddy_home",
        "selected": [
          "AGENTS.md",
          "SOUL.md",
          "USER.md",
          "MEMORY.md"
        ]
      },
      "color": "#0f766e",
      "binding": null
    },
    "context_budget_report": {
      "name": "context_budget_report",
      "description": "运行时生成的上下文预算与触发原因报告。",
      "type": "json",
      "value": {},
      "color": "#0e7490",
      "binding": null
    },
    "capability_result": {
      "name": "capability_result",
      "description": "能力执行后的结果包；只提取对会话连续性有帮助的摘要线索。",
      "type": "result_package",
      "value": {},
      "color": "#0284c7",
      "binding": null
    },
    "public_response": {
      "name": "public_response",
      "description": "本轮已展示或将展示给用户的公开回复。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    },
    "compaction_plan": {
      "name": "compaction_plan",
      "description": "压缩计划，包含保护头尾、摘要范围、预算和跳过理由。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "protected_recent_history": {
      "name": "protected_recent_history",
      "description": "需要在后续 prompt 中继续保留原文的最近会话片段。",
      "type": "markdown",
      "value": "",
      "color": "#0f766e",
      "binding": null
    },
    "session_summary_candidate": {
      "name": "session_summary_candidate",
      "description": "新的会话摘要候选，面向后续 Buddy 回复上下文。",
      "type": "markdown",
      "value": "",
      "color": "#4f46e5",
      "binding": null
    },
    "compaction_report": {
      "name": "compaction_report",
      "description": "压缩审计报告：触发原因、保留/省略数量、风险和写入决定。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "should_write_summary": {
      "name": "should_write_summary",
      "description": "是否应该通过 Buddy Home Writer 更新 session_summary。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": null
    },
    "writer_input": {
      "name": "writer_input",
      "description": "交给 Buddy Home Writer 的低风险 session_summary.update 命令计划。",
      "type": "json",
      "value": {
        "commands": []
      },
      "color": "#22c55e",
      "binding": null
    },
    "session_summary_write_success": {
      "name": "session_summary_write_success",
      "description": "Buddy Home Writer 是否成功应用 session_summary.update。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_session_summary",
        "fieldKey": "success",
        "managed": true
      }
    },
    "applied_session_summary_commands": {
      "name": "applied_session_summary_commands",
      "description": "已应用的 session summary 写回命令和 revision 信息。",
      "type": "json",
      "value": [],
      "color": "#059669",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_session_summary",
        "fieldKey": "applied_commands",
        "managed": true
      }
    },
    "skipped_session_summary_commands": {
      "name": "skipped_session_summary_commands",
      "description": "被跳过的 session summary 写回命令。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_session_summary",
        "fieldKey": "skipped_commands",
        "managed": true
      }
    },
    "session_summary_write_result": {
      "name": "session_summary_write_result",
      "description": "Buddy Home Writer 写回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#0369a1",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "nodeId": "write_session_summary",
        "fieldKey": "result",
        "managed": true
      }
    }
  },
