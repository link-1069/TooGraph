    "action_checklist": {
      "name": "行动清单",
      "description": "用户可执行的材料、办理入口、时间节点、核验事项和人工确认项。",
      "type": "json",
      "value": [],
      "color": "#0891b2",
      "binding": null
    },
    "citation_map": {
      "name": "引用映射",
