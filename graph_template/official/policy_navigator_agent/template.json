{
  "template_id": "policy_navigator_agent",
  "label": "政策导航助手",
  "description": "当用户需要理解政策原文、判断资格、整理办理清单、权益摘要和风险提示时使用。",
  "default_graph_name": "政策导航助手",
  "state_schema": {
    "policy_sources": {
      "name": "政策来源",
      "description": "政策来源链接、文件名、发布平台、用户粘贴的来源说明或 mock 来源清单。",
      "type": "text",
      "value": "示例：市人社局官网 2026-05-01 发布的《青年人才住房补贴申报指南》",
      "color": "#0f766e",
      "binding": null
    },
    "raw_policy_text": {
      "name": "政策正文",
      "description": "用户粘贴的政策正文、PDF/Word 抽取文本或 mock 政策文件正文。",
      "type": "markdown",
      "value": "",
      "color": "#2563eb",
      "binding": null
    },
    "policy_retrieval_context": {
      "name": "Policy Retrieval Context",
      "description": "Optional retrieval context_package, ranked_chunks, or retrieval scope notes. Use an empty object for lightweight mode.",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "user_profile": {
      "name": "用户画像",
      "description": "用户提供的年龄、身份、地区、就业/创业状态、社保、公积金、学历、企业信息或其他适用性信息。",
      "type": "markdown",
      "value": "示例：26 岁，应届硕士，计划在本市民营科技企业入职，未享受过人才住房补贴。",
      "color": "#d97706",
      "binding": null
    },
    "memory_request": {
      "name": "记忆召回请求",
      "description": "面向 buddy_session_recall Action 的只读召回参数。",
      "type": "json",
      "value": {},
      "color": "#4f46e5",
      "binding": null
    },
    "buddy_session_recall_success": {
      "name": "记忆召回成功",
      "description": "buddy_session_recall Action 是否成功执行。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_policy_memory",
        "fieldKey": "success",
        "managed": true
      }
    },
    "omitted_memories": {
      "name": "省略记忆",
      "description": "因预算或过滤条件未纳入的记忆摘要。",
      "type": "json",
      "value": [],
      "color": "#a855f7",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_policy_memory",
        "fieldKey": "omitted_memories",
        "managed": true
      }
    },
    "buddy_session_recall_result": {
      "name": "记忆召回摘要",
      "description": "buddy_session_recall Action 返回的召回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#6d28d9",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_policy_memory",
        "fieldKey": "result",
        "managed": true
