      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "binding": null
    },
    "session_recall_context": {
      "name": "session_recall_context",
      "description": "从 Buddy 历史会话中召回的上下文窗口。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_policy_memory",
        "fieldKey": "session_recall_context",
        "managed": true
      }
    },
    "recalled_sessions": {
      "name": "recalled_sessions",
      "description": "从 Buddy 历史会话中召回的会话片段。",
      "type": "json",
      "value": [],
      "color": "#7c3aed",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_session_recall",
        "nodeId": "recall_policy_memory",
        "fieldKey": "recalled_sessions",
        "managed": true
      }
    },
    "state_1": {
      "name": "Recall Request",
