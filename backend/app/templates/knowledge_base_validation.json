{
  "template_id": "knowledge_base_validation",
  "label": "知识库验证",
  "description": "Validate knowledge-base-backed agent flows against the current runtime.",
  "default_graph_name": "知识库验证",
  "state_schema": {
    "question": {
      "name": "question",
      "description": "User question for the workflow.",
      "type": "text",
      "value": "什么是 GraphiteUI？你能做些什么？我该如何开始使用？",
      "color": "#d97706"
    },
    "knowledge_base": {
      "name": "knowledge_base",
      "description": "Selected knowledge base for grounded answers.",
      "type": "knowledge_base",
      "value": "graphiteui-official",
      "color": "#0f766e"
    },
    "raw_answer": {
      "name": "raw_answer",
      "description": "Raw onboarding answer produced by the helper agent.",
      "type": "text",
      "value": "",
      "color": "#9f1239"
    },
    "formatted_answer": {
      "name": "formatted_answer",
      "description": "Markdown-formatted answer produced by the formatter agent.",
      "type": "text",
      "value": "",
      "color": "#7c3aed"
    }
  },
  "nodes": {
    "input_question": {
      "kind": "input",
      "name": "input_question",
      "description": "Provide the onboarding question that will be answered by downstream agents.",
      "ui": {
        "position": { "x": 80, "y": 160 },
        "collapsed": false
      },
      "writes": [
        { "state": "question", "mode": "replace" }
      ],
      "config": {
        "value": "什么是 GraphiteUI？你能做些什么？我该如何开始使用？"
      }
    },
    "input_knowledge_base": {
      "kind": "input",
      "name": "input_knowledge_base",
      "description": "Choose the knowledge base that grounds the onboarding answers.",
      "ui": {
        "position": { "x": 80, "y": 540 },
        "collapsed": false
      },
      "writes": [
        { "state": "knowledge_base", "mode": "replace" }
      ],
      "config": {
        "value": "graphiteui-official"
      }
    },
    "onboarding_helper": {
      "kind": "agent",
      "name": "onboarding_helper",
      "description": "Use the selected knowledge base to produce an onboarding answer.",
      "ui": {
        "position": { "x": 560, "y": 80 },
        "collapsed": false
      },
      "reads": [
        { "state": "question", "required": true },
        { "state": "knowledge_base", "required": true }
      ],
      "writes": [
        { "state": "raw_answer", "mode": "replace" }
      ],
      "config": {
        "skills": ["search_knowledge_base"],
        "systemInstruction": "",
        "taskInstruction": ""
      }
    },
    "markdown_formatter": {
      "kind": "agent",
      "name": "markdown_formatter",
      "description": "Rewrite the onboarding answer into a cleaner markdown response.",
      "ui": {
        "position": { "x": 560, "y": 480 },
        "collapsed": false
      },
      "reads": [
        { "state": "question", "required": true },
        { "state": "knowledge_base", "required": true }
      ],
      "writes": [
        { "state": "formatted_answer", "mode": "replace" }
      ],
      "config": {
        "skills": ["search_knowledge_base"],
        "systemInstruction": "",
        "taskInstruction": "使用markdown格式输出"
      }
    },
    "output_raw_answer": {
      "kind": "output",
      "name": "output_raw_answer",
      "description": "Show the helper agent's raw answer before any formatting pass.",
      "ui": {
        "position": { "x": 1040, "y": 80 },
        "collapsed": false
      },
      "reads": [
        { "state": "raw_answer", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_formatted_answer": {
      "kind": "output",
      "name": "output_formatted_answer",
      "description": "Show the markdown-formatted onboarding answer.",
      "ui": {
        "position": { "x": 1040, "y": 480 },
        "collapsed": false
      },
      "reads": [
        { "state": "formatted_answer", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_question",
      "target": "onboarding_helper"
    },
    {
      "source": "input_knowledge_base",
      "target": "onboarding_helper"
    },
    {
      "source": "input_question",
      "target": "markdown_formatter"
    },
    {
      "source": "input_knowledge_base",
      "target": "markdown_formatter"
    },
    {
      "source": "onboarding_helper",
      "target": "output_raw_answer"
    },
    {
      "source": "markdown_formatter",
      "target": "output_formatted_answer"
    }
  ],
  "conditional_edges": [],
  "metadata": {}
}
