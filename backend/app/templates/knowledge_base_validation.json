{
  "template_id": "knowledge_base_validation",
  "label": "知识库问答",
  "description": "Use a selected knowledge base to answer a user question with one grounded agent.",
  "default_graph_name": "知识库问答",
  "state_schema": {
    "question": {
      "name": "question",
      "description": "Question that should be answered from the knowledge base.",
      "type": "text",
      "value": "GraphiteUI 支持哪些核心能力？",
      "color": "#d97706"
    },
    "knowledge_base": {
      "name": "knowledge_base",
      "description": "Selected knowledge base for grounded answers.",
      "type": "knowledge_base",
      "value": "graphiteui-official",
      "color": "#0f766e"
    },
    "answer": {
      "name": "answer",
      "description": "Knowledge-base-grounded answer produced by the agent.",
      "type": "text",
      "value": "",
      "color": "#7c3aed"
    }
  },
  "nodes": {
    "input_question": {
      "kind": "input",
      "name": "input_question",
      "description": "Provide the question to answer.",
      "ui": {
        "position": { "x": 80, "y": 160 },
        "collapsed": false
      },
      "writes": [
        { "state": "question", "mode": "replace" }
      ],
      "config": {
        "value": "GraphiteUI 支持哪些核心能力？"
      }
    },
    "input_knowledge_base": {
      "kind": "input",
      "name": "input_knowledge_base",
      "description": "Choose the knowledge base that grounds the answer.",
      "ui": {
        "position": { "x": 80, "y": 640 },
        "collapsed": false
      },
      "writes": [
        { "state": "knowledge_base", "mode": "replace" }
      ],
      "config": {
        "value": "graphiteui-official"
      }
    },
    "kb_answer_agent": {
      "kind": "agent",
      "name": "kb_answer_agent",
      "description": "Search the selected knowledge base and answer the question.",
      "ui": {
        "position": { "x": 760, "y": 320 },
        "collapsed": false
      },
      "reads": [
        { "state": "question", "required": true },
        { "state": "knowledge_base", "required": true }
      ],
      "writes": [
        { "state": "answer", "mode": "replace" }
      ],
      "config": {
        "skills": ["search_knowledge_base"],
        "taskInstruction": "请优先使用知识库检索结果回答问题，回答要准确、简洁；如果知识库依据不足，请明确说明。"
      }
    },
    "output_answer": {
      "kind": "output",
      "name": "output_answer",
      "description": "Show the grounded answer.",
      "ui": {
        "position": { "x": 1440, "y": 320 },
        "collapsed": false
      },
      "reads": [
        { "state": "answer", "required": true }
      ],
      "config": {
        "displayMode": "markdown",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_question",
      "target": "kb_answer_agent"
    },
    {
      "source": "input_knowledge_base",
      "target": "kb_answer_agent"
    },
    {
      "source": "kb_answer_agent",
      "target": "output_answer"
    }
  ],
  "conditional_edges": [],
  "metadata": {}
}
