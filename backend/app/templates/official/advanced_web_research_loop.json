{
  "template_id": "advanced_web_research_loop",
  "label": "高级联网搜索",
  "description": "多轮搜索、证据评估、补充检索和最终依据整理的联网研究图模板。",
  "default_graph_name": "高级联网搜索",
  "state_schema": {
    "user_question": {
      "name": "用户问题",
      "description": "用户要研究、核查或总结的问题。",
      "type": "text",
      "value": "帮我总结今天的 AI 新闻",
      "color": "#d97706",
      "promptVisible": true,
      "binding": null
    },
    "research_plan": {
      "name": "研究计划",
      "description": "搜索目标、覆盖面、证据充足标准和首轮检索方向。",
      "type": "markdown",
      "value": "",
      "color": "#2563eb",
      "promptVisible": true,
      "binding": null
    },
    "current_query": {
      "name": "当前搜索词",
      "description": "本轮要交给联网搜索技能的查询词。",
      "type": "text",
      "value": "",
      "color": "#0f766e",
      "promptVisible": true,
      "binding": null
    },
    "executed_queries": {
      "name": "联网搜索 Query",
      "description": "联网搜索技能实际执行过的查询词列表。",
      "type": "json",
      "value": [],
      "color": "#7c3aed",
      "promptVisible": true,
      "binding": {
        "kind": "skill_output",
        "skillKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "query",
        "managed": true
      }
    },
    "source_urls": {
      "name": "联网搜索 Source URLs",
      "description": "成功保存为本地原文文档的来源 URL 列表。",
      "type": "json",
      "value": [],
      "color": "#9333ea",
      "promptVisible": false,
      "binding": {
        "kind": "skill_output",
        "skillKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "source_urls",
        "managed": true
      }
    },
    "artifact_paths": {
      "name": "联网搜索 Artifact Paths",
      "description": "成功下载到本地的网页正文文件路径列表；每个文件头部包含 Source URL 原文地址。",
      "type": "file",
      "value": [],
      "color": "#10b981",
      "promptVisible": true,
      "binding": {
        "kind": "skill_output",
        "skillKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "artifact_paths",
        "managed": true
      }
    },
    "search_errors": {
      "name": "联网搜索 Errors",
      "description": "搜索或正文下载过程中发生的错误列表。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "promptVisible": true,
      "binding": {
        "kind": "skill_output",
        "skillKey": "web_search",
        "nodeId": "run_web_search",
        "fieldKey": "errors",
        "managed": true
      }
    },
    "evidence_review": {
      "name": "证据评估",
      "description": "对当前资料是否足够回答问题的结构化评估。",
      "type": "json",
      "value": {},
      "color": "#0891b2",
      "promptVisible": true,
      "binding": null
    },
    "key_evidence_notes": {
      "name": "关键依据笔记",
      "description": "最终回答前筛选出的核心依据文档、支持点和局限。",
      "type": "markdown",
      "value": "",
      "color": "#4f46e5",
      "promptVisible": true,
      "binding": null
    },
    "final_reply": {
      "name": "最终回复",
      "description": "面向用户展示的最终整理结果。",
      "type": "markdown",
      "value": "",
      "color": "#b45309",
      "promptVisible": true,
      "binding": null
    }
  },
  "nodes": {
    "input_question": {
      "kind": "input",
      "name": "输入问题",
      "description": "提供要联网研究的问题。",
      "ui": {
        "position": { "x": 40, "y": 280 },
        "collapsed": false,
        "size": { "width": 300, "height": 180 }
      },
      "reads": [],
      "writes": [{ "state": "user_question", "mode": "replace" }],
      "config": {
        "value": "帮我总结今天的 AI 新闻",
        "boundaryType": "text"
      }
    },
    "plan_search": {
      "kind": "agent",
      "name": "制定搜索计划",
      "description": "把用户问题转成可执行的研究计划和首轮搜索词。",
      "ui": {
        "position": { "x": 440, "y": 220 },
        "collapsed": false,
        "size": { "width": 380, "height": 260 }
      },
      "reads": [{ "state": "user_question", "required": true }],
      "writes": [
        { "state": "research_plan", "mode": "replace" },
        { "state": "current_query", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "你负责把用户问题转成可执行的联网研究计划。research_plan 写成简洁 Markdown，包含研究目标、需要覆盖的关键问题、证据充足标准和最多补充搜索轮次。current_query 只能写一条适合公开网页检索的首轮搜索词，不要写解释。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "run_web_search": {
      "kind": "agent",
      "name": "运行联网搜索",
      "description": "根据当前搜索词运行联网搜索技能，只透传技能输出。",
      "ui": {
        "position": { "x": 900, "y": 220 },
        "collapsed": false,
        "size": { "width": 420, "height": 300 }
      },
      "reads": [
        { "state": "user_question", "required": true },
        { "state": "research_plan", "required": true },
        { "state": "current_query", "required": true }
      ],
      "writes": [
        { "state": "executed_queries", "mode": "append" },
        { "state": "source_urls", "mode": "append" },
        { "state": "artifact_paths", "mode": "append" },
        { "state": "search_errors", "mode": "append" }
      ],
      "config": {
        "skills": ["web_search"],
        "skillBindings": [
          {
            "skillKey": "web_search",
            "outputMapping": {
              "query": "executed_queries",
              "source_urls": "source_urls",
              "artifact_paths": "artifact_paths",
              "errors": "search_errors"
            }
          }
        ],
        "skillInstructionBlocks": {
          "web_search": {
            "skillKey": "web_search",
            "title": "联网搜索 skill instruction",
            "content": "你已绑定联网搜索技能，因此本节点需要运行它。根据当前输入生成一个清晰、可检索的 query，并把 query 交给技能执行；不要在本节点整理、评价或总结搜索结果。技能结果会通过绑定 state 透传给下游节点。",
            "source": "skill.agentInstruction"
          }
        },
        "taskInstruction": "本节点只负责运行联网搜索技能。优先把 current_query 原样作为技能 query；如果 current_query 为空，才从用户问题和研究计划中生成一个 query。不要总结、评价或改写搜索结果。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "review_evidence": {
      "kind": "agent",
      "name": "评估证据并生成补搜词",
      "description": "阅读已下载的原文，判断是否需要补充搜索，并在需要时写出下一轮搜索词。",
      "ui": {
        "position": { "x": 1400, "y": 220 },
        "collapsed": false,
        "size": { "width": 420, "height": 300 }
      },
      "reads": [
        { "state": "user_question", "required": true },
        { "state": "research_plan", "required": true },
        { "state": "current_query", "required": true },
        { "state": "executed_queries", "required": false },
        { "state": "artifact_paths", "required": false },
        { "state": "search_errors", "required": false }
      ],
      "writes": [
        { "state": "evidence_review", "mode": "replace" },
        { "state": "current_query", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "阅读 artifact_paths 中的本地原文，判断当前证据是否足以回答用户问题。evidence_review 必须写成 JSON 对象，包含 needs_more_search(boolean)、confidence(0 到 1)、reason、missing_aspects(array)、next_query(string)。只有在资料为空、明显跑偏、少于 3 份可读原文，或缺少的关键角度会直接阻止回答时，才把 needs_more_search 设为 true。若已经有约 5 份可读原文并且能回答用户问题，即使仍可继续寻找一手来源，也应把 needs_more_search 设为 false，并在 reason 中说明证据局限；不要为了追求完美来源而反复补搜。如果 needs_more_search 为 true，给出一条更窄、更具体、避免重复 executed_queries 的 next_query，并把 current_query 写成同一条 next_query；如果已经足够，current_query 保留当前搜索词即可。不要写最终答案。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "should_continue_search": {
      "kind": "condition",
      "name": "是否补充搜索",
      "description": "根据证据评估决定进入补搜循环还是整理答案；达到 loopLimit 时走 exhausted 分支并用已有资料收束。",
      "ui": {
        "position": { "x": 1900, "y": 260 },
        "collapsed": false,
        "size": { "width": 280, "height": 180 }
      },
      "reads": [{ "state": "evidence_review", "required": true }],
      "writes": [],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 5,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.evidence_review.needs_more_search",
          "operator": "==",
          "value": true
        }
      }
    },
    "select_evidence": {
      "kind": "agent",
      "name": "筛选关键依据",
      "description": "从原文中挑出最重要的依据文档和支持点。",
      "ui": {
        "position": { "x": 2260, "y": 200 },
        "collapsed": false,
        "size": { "width": 420, "height": 300 }
      },
      "reads": [
        { "state": "user_question", "required": true },
        { "state": "research_plan", "required": true },
        { "state": "artifact_paths", "required": false },
        { "state": "evidence_review", "required": false },
        { "state": "search_errors", "required": false }
      ],
      "writes": [{ "state": "key_evidence_notes", "mode": "replace" }],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "从已下载原文中筛选最重要的 3 到 5 个依据文档。每份原文头部都有 Source URL 原文地址；key_evidence_notes 写成 Markdown 时，每个依据必须用网页 URL/原文地址标识，说明它支持了什么事实、为什么重要、还有什么局限。不要把 doc_001.md 这类本地文件名当作证据来源。只做依据整理，不写面向用户的最终回答。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "final_answer": {
      "kind": "agent",
      "name": "整理最终回复",
      "description": "基于关键依据和原文生成给用户看的最终结果。",
      "ui": {
        "position": { "x": 2760, "y": 200 },
        "collapsed": false,
        "size": { "width": 420, "height": 300 }
      },
      "reads": [
        { "state": "user_question", "required": true },
        { "state": "key_evidence_notes", "required": true },
        { "state": "artifact_paths", "required": false },
        { "state": "search_errors", "required": false }
      ],
      "writes": [{ "state": "final_reply", "mode": "replace" }],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "根据关键依据笔记和本地原文生成最终回复。先直接回答用户问题，再列出最重要依据；依据来源必须写网页 URL/原文地址和关键信息，不要引用 doc_001.md 这类本地文件名，不要编造原文中不存在的事实。若资料不足，明确说明缺口和已尝试的搜索。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "output_final": {
      "kind": "output",
      "name": "最终回复",
      "description": "展示最终整理结果。",
      "ui": {
        "position": { "x": 3260, "y": 60 },
        "collapsed": false,
        "size": { "width": 420, "height": 260 }
      },
      "reads": [{ "state": "final_reply", "required": true }],
      "writes": [],
      "config": {
        "displayMode": "markdown",
        "persistEnabled": false,
        "persistFormat": "md",
        "fileNameTemplate": ""
      }
    },
    "output_evidence": {
      "kind": "output",
      "name": "关键依据",
      "description": "展示最终回答采用的依据笔记。",
      "ui": {
        "position": { "x": 3260, "y": 360 },
        "collapsed": false,
        "size": { "width": 420, "height": 260 }
      },
      "reads": [{ "state": "key_evidence_notes", "required": true }],
      "writes": [],
      "config": {
        "displayMode": "markdown",
        "persistEnabled": false,
        "persistFormat": "md",
        "fileNameTemplate": ""
      }
    },
    "output_documents": {
      "kind": "output",
      "name": "依据原文",
      "description": "展示已下载到本地的原文文档。",
      "ui": {
        "position": { "x": 3260, "y": 660 },
        "collapsed": false,
        "size": { "width": 420, "height": 260 }
      },
      "reads": [{ "state": "artifact_paths", "required": false }],
      "writes": [],
      "config": {
        "displayMode": "documents",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    { "source": "input_question", "target": "plan_search" },
    { "source": "plan_search", "target": "run_web_search" },
    { "source": "run_web_search", "target": "review_evidence" },
    { "source": "review_evidence", "target": "should_continue_search" },
    { "source": "select_evidence", "target": "final_answer" },
    { "source": "final_answer", "target": "output_final" },
    { "source": "final_answer", "target": "output_evidence" },
    { "source": "final_answer", "target": "output_documents" }
  ],
  "conditional_edges": [
    {
      "source": "should_continue_search",
      "branches": {
        "true": "run_web_search",
        "false": "select_evidence",
        "exhausted": "select_evidence"
      }
    }
  ],
  "metadata": {
    "category": "research",
    "templateVersion": "2026-05-07",
    "maxSearchRounds": 5,
    "graphProtocol": "node_system"
  }
}
