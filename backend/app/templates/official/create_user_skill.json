  "nodes": {
    "input_skill_idea": {
      "kind": "input",
      "name": "输入技能想法",
      "description": "描述希望创建的自定义 Skill。",
      "ui": { "position": { "x": 40, "y": 360 }, "collapsed": false, "size": { "width": 320, "height": 190 } },
      "reads": [],
      "writes": [{ "state": "skill_idea", "mode": "replace" }],
      "config": { "value": "我想创建一个能处理本地文本并返回结构化摘要的技能。", "boundaryType": "markdown" }
    },
    "inspect_existing_skills": {
      "kind": "agent",
      "name": "检查现有技能",
      "description": "读取官方和用户 Skill 摘要，给后续节点判断是否已有能力可复用。",
      "ui": { "position": { "x": 440, "y": 300 }, "collapsed": false, "size": { "width": 400, "height": 260 } },
      "reads": [{ "state": "skill_idea", "required": true }],
      "writes": [
        { "state": "existing_skill_catalog", "mode": "replace" },
        { "state": "builder_result", "mode": "replace" }
      ],
      "config": {
        "skills": ["graphiteUI_skill_builder"],
        "skillBindings": [
          {
            "skillKey": "graphiteUI_skill_builder",
            "outputMapping": {
              "skill_catalog": "existing_skill_catalog",
              "builder_result": "builder_result"
            }
          }
        ],
        "skillInstructionBlocks": {
          "graphiteUI_skill_builder": {
            "skillKey": "graphiteUI_skill_builder",
            "title": "检查现有 Skill",
            "content": "调用 action=inspect_existing_skills，不要传 skill_key 或 files。只返回现有官方和用户 Skill 摘要。",
            "source": "skill.agentInstruction"
          }
        },
        "taskInstruction": "调用 graphiteUI_skill_builder，action 必须是 inspect_existing_skills。不要回答用户，不要生成 Skill 文件。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "medium",
        "temperature": 0.1
      }
    },
    "clarify_requirements": {
      "kind": "agent",
      "name": "澄清需求",
      "description": "判断已有 Skill 是否满足需求，并生成带选项的澄清问题。",
      "ui": { "position": { "x": 920, "y": 260 }, "collapsed": false, "size": { "width": 430, "height": 300 } },
      "reads": [
        { "state": "skill_idea", "required": true },
        { "state": "existing_skill_catalog", "required": false }
      ],
      "writes": [
        { "state": "existing_skill_match", "mode": "replace" },
        { "state": "clarification_questions", "mode": "replace" },
        { "state": "requirements_draft", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "根据 skill_idea 和 existing_skill_catalog 判断是否已有 Skill 可以满足需求。existing_skill_match 写 JSON，包含 can_reuse_existing(boolean)、matching_skill_keys(array)、reason、recommendation。requirements_draft 写 Markdown，总结你当前理解的目标、输入、输出、权限、失败情况和验收标准。clarification_questions 写 JSON 数组；每个问题包含 id、question、why、options，其中 options 尽量给 2 到 4 个可选项，但允许用户自定义回答。如果需求已经足够清晰，也至少给一个确认问题，让用户在断点处确认或补充。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "refine_requirements": {
      "kind": "agent",
      "name": "整理确认需求",
      "description": "把用户在断点处填写的澄清回答整理成可实现需求。",
      "ui": { "position": { "x": 1420, "y": 260 }, "collapsed": false, "size": { "width": 430, "height": 300 } },
      "reads": [
        { "state": "skill_idea", "required": true },
        { "state": "requirements_draft", "required": true },
        { "state": "clarification_questions", "required": false },
        { "state": "clarification_answers", "required": true }
      ],
      "writes": [{ "state": "accepted_requirements", "mode": "replace" }],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "根据用户澄清回答整理最终需求。accepted_requirements 写 Markdown，必须包含目标、非目标、输入字段、输出字段、权限和副作用、错误处理、示例验收标准、测试策略。不要生成代码。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "draft_examples": {
      "kind": "agent",
      "name": "生成示例输入输出",
      "description": "根据确认需求生成示例输入、预期输出和 smoke test 输入。",
      "ui": { "position": { "x": 1920, "y": 260 }, "collapsed": false, "size": { "width": 430, "height": 300 } },
      "reads": [
        { "state": "accepted_requirements", "required": true },
        { "state": "example_feedback", "required": false }
      ],
      "writes": [{ "state": "example_io", "mode": "replace" }],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "生成用户可确认的示例输入输出。example_io 必须是 JSON 对象，包含 skill_input_example、expected_output_example、acceptance_checks、edge_cases、smoke_input。若 example_feedback 不为空，优先按反馈修订。不要生成 Skill 文件。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "should_accept_examples": {
      "kind": "condition",
      "name": "示例是否确认",
      "description": "用户确认示例后进入设计，否则带反馈重新生成示例。",
      "ui": { "position": { "x": 2420, "y": 300 }, "collapsed": false, "size": { "width": 290, "height": 180 } },
      "reads": [{ "state": "example_approval", "required": true }],
      "writes": [],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 3,
        "branchMapping": { "true": "true", "false": "false" },
        "rule": { "source": "$state.example_approval", "operator": "==", "value": "approved" }
      }
    },
    "design_skill": {
      "kind": "agent",
      "name": "设计技能包",
      "description": "生成正式写文件前的 Skill 设计，等待用户确认。",
      "ui": { "position": { "x": 2860, "y": 260 }, "collapsed": false, "size": { "width": 440, "height": 320 } },
      "reads": [
        { "state": "accepted_requirements", "required": true },
        { "state": "example_io", "required": true },
        { "state": "design_feedback", "required": false }
      ],
      "writes": [{ "state": "skill_design", "mode": "replace" }],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "设计一个 GraphiteUI Skill 包。skill_design 必须是 JSON 对象，包含 skill_key、name、description、permissions、input_schema、output_schema、runtime、files_to_generate、smoke_test_plan、risks。skill_key 必须适合作为路径名，不能包含 /、\\ 或冒号。只设计，不写文件。若 design_feedback 不为空，优先按反馈修订。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "should_accept_design": {
      "kind": "condition",
      "name": "设计是否确认",
      "description": "用户确认设计后生成文件，否则带反馈重新设计。",
      "ui": { "position": { "x": 3380, "y": 300 }, "collapsed": false, "size": { "width": 290, "height": 180 } },
      "reads": [{ "state": "design_approval", "required": true }],
      "writes": [],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 3,
        "branchMapping": { "true": "true", "false": "false" },
        "rule": { "source": "$state.design_approval", "operator": "==", "value": "approved" }
      }
    },
    "generate_skill_files": {
      "kind": "agent",
      "name": "生成 Skill 文件",
      "description": "根据确认设计生成完整 Skill 包文件和 smoke test 输入。",
      "ui": { "position": { "x": 3820, "y": 240 }, "collapsed": false, "size": { "width": 460, "height": 340 } },
      "reads": [
        { "state": "accepted_requirements", "required": true },
        { "state": "example_io", "required": true },
        { "state": "skill_design", "required": true }
      ],
      "writes": [
        { "state": "target_skill_key", "mode": "replace" },
        { "state": "generated_skill_files", "mode": "replace" },
        { "state": "smoke_input", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "生成完整 GraphiteUI Skill 包。target_skill_key 写 skill_design.skill_key。generated_skill_files 必须是 JSON 对象，键为相对路径，至少包含 skill.json、SKILL.md、run.py；值为完整 UTF-8 文本内容。skill.json 必须包含 schemaVersion=graphite.skill/v1、skillKey、name、description、agentInstruction、version、kind、mode、scope、permissions、inputSchema、outputSchema、runtime、health、configured、healthy。run.py 必须从 stdin 读取 JSON，向 stdout 打印 JSON 对象。smoke_input 使用 example_io.smoke_input 或 skill_input_example。不要写压缩包，不要写官方目录。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "xhigh",
        "temperature": 0.2
      }
    },
    "write_skill_package": {
      "kind": "agent",
      "name": "写入并测试 Skill",
      "description": "调用 GraphiteUI Skill Builder 写入用户 Skill 包并运行 smoke test。",
      "ui": { "position": { "x": 4360, "y": 240 }, "collapsed": false, "size": { "width": 460, "height": 340 } },
      "reads": [
        { "state": "target_skill_key", "required": true },
        { "state": "generated_skill_files", "required": true },
        { "state": "smoke_input", "required": false }
      ],
      "writes": [
        { "state": "builder_result", "mode": "replace" },
        { "state": "test_status", "mode": "replace" },
        { "state": "validation_errors", "mode": "replace" },
        { "state": "builder_errors", "mode": "replace" },
        { "state": "builder_warnings", "mode": "replace" },
        { "state": "test_stdout", "mode": "replace" },
        { "state": "test_stderr", "mode": "replace" },
        { "state": "final_skill_path", "mode": "replace" },
