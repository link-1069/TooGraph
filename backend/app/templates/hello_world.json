{
  "template_id": "hello_world",
  "label": "Hello World",
  "description": "A minimal greeting workflow: provide a name and let one agent generate a short welcome message.",
  "default_graph_name": "Hello World",
  "state_schema": {
    "name": {
      "name": "name",
      "description": "Name or audience to greet.",
      "type": "text",
      "value": "GraphiteUI 用户",
      "color": "#d97706"
    },
    "greeting": {
      "name": "greeting",
      "description": "Greeting generated by the agent.",
      "type": "text",
      "value": "",
      "color": "#7c3aed"
    }
  },
  "nodes": {
    "input_name": {
      "kind": "input",
      "name": "input_name",
      "description": "Provide the name that should be greeted.",
      "ui": {
        "position": { "x": 80, "y": 220 },
        "collapsed": false
      },
      "writes": [
        { "state": "name", "mode": "replace" }
      ],
      "config": {
        "value": "GraphiteUI 用户"
      }
    },
    "greeting_agent": {
      "kind": "agent",
      "name": "greeting_agent",
      "description": "Create a short friendly greeting.",
      "ui": {
        "position": { "x": 760, "y": 220 },
        "collapsed": false
      },
      "reads": [
        { "state": "name", "required": true }
      ],
      "writes": [
        { "state": "greeting", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "taskInstruction": "读取输入 name，用中文生成一句简短、友好的欢迎语。只输出问候内容，不要解释。"
      }
    },
    "output_greeting": {
      "kind": "output",
      "name": "output_greeting",
      "description": "Preview the final greeting.",
      "ui": {
        "position": { "x": 1440, "y": 220 },
        "collapsed": false
      },
      "reads": [
        { "state": "greeting", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_name",
      "target": "greeting_agent"
    },
    {
      "source": "greeting_agent",
      "target": "output_greeting"
    }
  ],
  "conditional_edges": [],
  "metadata": {}
}
