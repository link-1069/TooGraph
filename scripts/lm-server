#!/usr/bin/env bash
set -euo pipefail

cat >&2 <<'EOF'
[GraphiteUI] This legacy local runtime wrapper has moved to EZLLM.

Use EZLLM instead:
  pipx install ezllm
  ezllm start

Then point GraphiteUI at:
  LOCAL_BASE_URL=http://127.0.0.1:8888/v1

This wrapper only exists to guide migration and exits without starting a runtime.
EOF

exit 1
